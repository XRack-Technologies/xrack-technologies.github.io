# GA4 Measurement ID for consent-gated analytics (see docs/analytics.md).
PUBLIC_GA_ID=

# Search-engine ownership verification (HTML-tag method). See docs/seo.md.
PUBLIC_GOOGLE_VERIFICATION=
PUBLIC_BING_VERIFICATION=

# Giscus comments (GitHub Discussions). From https://giscus.app. See docs/comments.md.
# When repo/repo-id/category-id are empty, posts show discussion links instead.
PUBLIC_GISCUS_REPO=
PUBLIC_GISCUS_REPO_ID=
PUBLIC_GISCUS_CATEGORY=
PUBLIC_GISCUS_CATEGORY_ID=
