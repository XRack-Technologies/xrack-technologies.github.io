<script>
  document.getElementById("resetConsent")?.addEventListener("click", () => {
    try { localStorage.removeItem("xrack-analytics-consent"); } catch (e) {}
    location.reload();
  });

  const links = Array.from(document.querySelectorAll<HTMLAnchorElement>(".toc-a"));
  const byId = new Map<string, HTMLAnchorElement>();
  links.forEach((a) => {
    const id = decodeURIComponent((a.getAttribute("href") || "").slice(1));
    if (id) byId.set(id, a);
  });
  const sections = Array.from(document.querySelectorAll<HTMLElement>(".pv-section"));
  if (sections.length && byId.size) {
    let current = "";
    const setActive = (id: string) => {
      if (id === current) return;
      current = id;
      links.forEach((a) => a.classList.remove("is-active"));
      byId.get(id)?.classList.add("is-active");
    };
    const onScroll = () => {
      let active = sections[0].id;
      for (const sec of sections) {
        if (sec.getBoundingClientRect().top < 140) active = sec.id;
        else break;
      }
      setActive(active);
    };
    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener("resize", onScroll, { passive: true });
    onScroll();
  }
</script>
