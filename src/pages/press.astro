---
import Base from "../layouts/Base.astro";
import T from "../components/T.astro";
import { href, SITE, SOCIAL } from "../lib/site";
import { AUTHORS } from "../lib/authors";

const logo = href("logo.png");
const mascot = href("press/raxclaw.png");
const execs = Object.values(AUTHORS);
const initials = (name: string) => {
  const w = name.split(/\s+/).filter(Boolean);
  return ((w[0]?.[0] ?? "") + (w.length > 1 ? (w[w.length - 1][0] ?? "") : "")).toUpperCase();
};
const pressEmail = "support@xrack.io";
const ogCard = Astro.site ? new URL(href("press/og-card.png"), Astro.site).href : href("press/og-card.png");

const LINKEDIN_SVG =
  '<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>';
const GITHUB_SVG =
  '<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.605-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0 1 12 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222 0 1.606-.014 2.898-.014 3.293 0 .322.216.694.825.576C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>';
const socialLabel = (u: string) => u.replace(/^https?:\/\/(www\.)?/, "").split("/")[0];

const facts: { k: { en: string; tr: string }; v: { en: string; tr: string }; url?: string }[] = [
  { k: { en: "Company", tr: "Şirket" }, v: { en: "XRack Technologies", tr: "XRack Technologies" } },
  { k: { en: "Product", tr: "Ürün" }, v: { en: "XRack — Sovereign Cognitive Runtime", tr: "XRack — Sovereign Cognitive Runtime" } },
  { k: { en: "Category", tr: "Kategori" }, v: { en: "Enterprise AI · agent infrastructure", tr: "Kurumsal yapay zekâ · ajan altyapısı" } },
  { k: { en: "Architecture", tr: "Mimari" }, v: { en: "Four planes — Harness · Grid · Federation · Embodiment", tr: "Dört düzlem — Harness · Grid · Federation · Embodiment" } },
  { k: { en: "Deployment", tr: "Dağıtım" }, v: { en: "Self-hosted appliance · bring your own LLM", tr: "Kendi altyapınızda · kendi LLM'iniz" } },
  { k: { en: "Founded", tr: "Kuruluş" }, v: { en: "2025", tr: "2025" } },
  { k: { en: "Website", tr: "Web sitesi" }, v: { en: "xrack.io", tr: "xrack.io" }, url: SITE.homepage },
  { k: { en: "Press contact", tr: "Basın iletişimi" }, v: { en: pressEmail, tr: pressEmail }, url: `mailto:${pressEmail}` },
];

const oneLinerEn =
  "XRack is a sovereign cognitive runtime that turns enterprise AI from an opaque black box into an auditable glass box.";
const oneLinerTr =
  "XRack, kurumsal yapay zekâyı opak bir kara kutudan denetlenebilir bir cam kutuya dönüştüren, bağımsız bir bilişsel çalışma zamanıdır.";
const boilerShortEn =
  "XRack Technologies builds a self-hosted cognitive runtime for regulated enterprise AI. The model proposes, the runtime executes, the ledger proves — agents that remember, act, verify, and prove every decision, running inside the customer's own perimeter, on their own LLM, with their own audit trail.";
const boilerShortTr =
  "XRack Technologies, regüle kurumsal yapay zekâ için kendi altyapınızda barındırılan bir bilişsel runtime geliştirir. Model önerir, runtime uygular, defter kanıtlar — hatırlayan, eyleme geçen, doğrulayan ve verdiği her kararı kanıtlayan ajanlar; müşterinin kendi çevresinde, kendi LLM'iyle ve kendi denetim kaydıyla çalışır.";
const boilerLongEn =
  "One runtime, four planes — a harness (the mind), a grid (the organization), a federation (the portfolio), and embodiment (the body). Free-form prompt loops drift and, when they fail, cannot say why — so regulated organizations can't run them. XRack replaces the open-ended loop with a deterministic cognitive cycle (observe → reason → plan → act → verify → learn) and an immutable ledger: every step is traced, every decision carries its own evidence, and every grant of authority is scoped and expiring. It ships self-hosted, bring your own LLM, and fails closed by default.";
const boilerLongTr =
  "Tek runtime, dört düzlem — bir harness (zihin), bir grid (organizasyon), bir federation (portföy) ve embodiment (beden). Serbest biçimli prompt döngüleri savrulur ve hata verdiklerinde nedenini söyleyemez; bu yüzden regüle kurumlar onları çalıştıramaz. XRack, açık uçlu döngünün yerine deterministik bir bilişsel döngü (gözlemle → akıl yürüt → planla → eyleme geç → doğrula → öğren) ve değiştirilemez bir defter koyar: her adım izlenir, her karar kendi kanıtını taşır ve her yetki kapsamlı ve sürelidir. Kendi altyapınızda barındırılır, kendi LLM'inizi getirir ve varsayılan olarak kapalı başlar.";

const boilers = [
  { tag: { en: "One-liner", tr: "Tek cümle" }, en: oneLinerEn, tr: oneLinerTr },
  { tag: { en: "Short", tr: "Kısa" }, en: boilerShortEn, tr: boilerShortTr },
  { tag: { en: "Long", tr: "Uzun" }, en: boilerLongEn, tr: boilerLongTr },
];

const downloads = [
  { src: logo, name: { en: "Logo mark", tr: "Logo işareti" }, meta: "PNG · 512×512", tone: "mark", dl: "xrack-logo.png" },
  { src: mascot, name: { en: "Brand mascot", tr: "Marka maskotu" }, meta: "PNG · 1254×1254", tone: "art", dl: "xrack-mascot.png" },
  { src: href("press/og-card.png"), name: { en: "Share card — EN", tr: "Paylaşım kartı — EN" }, meta: "PNG · 1200×630", tone: "wide", dl: "xrack-share-en.png" },
  { src: href("press/og-card-tr.png"), name: { en: "Share card — TR", tr: "Paylaşım kartı — TR" }, meta: "PNG · 1200×630", tone: "wide", dl: "xrack-share-tr.png" },
];

const imagery = [
  { f: "architecture", en: "Architecture", tr: "Mimari" },
  { f: "system_map", en: "System map", tr: "Sistem haritası" },
  { f: "ledger", en: "Ledger", tr: "Defter" },
  { f: "reasoning", en: "Reasoning", tr: "Akıl yürütme" },
  { f: "memory_graph", en: "Memory graph", tr: "Bellek grafiği" },
  { f: "planning", en: "Planning", tr: "Planlama" },
  { f: "pipeline", en: "Pipeline", tr: "İşlem hattı" },
  { f: "security", en: "Security", tr: "Güvenlik" },
  { f: "capabilities", en: "Capabilities", tr: "Yetenekler" },
  { f: "metrics", en: "Metrics", tr: "Metrikler" },
];
---

<Base
  title="Press & Media Kit"
  description="Brand assets, boilerplate, editorial artwork, executive bios, and a media contact for XRack Technologies."
  image={ogCard}
>
  <!-- Hero -->
  <section class="hero press-hero">
    <div class="hero-aura"></div>
    <div class="press-hero__grid"></div>
    <div class="wrap press-hero__grid-wrap">
      <div class="press-hero__copy reveal-on-view">
        <span class="status-chip"><span class="dot"></span> <T en="Press · Media Kit" tr="Basın · Medya Kiti" /></span>
        <h1 class="display-title press-hero__title">
          <T en="Press &" tr="Basın &" /> <span class="hero-accent"><T en="Media Kit" tr="Medya Kiti" /></span>
        </h1>
        <p class="lede press-hero__lede">
          <T
            en="Everything you need to cover XRack accurately — logo and brand assets, approved boilerplate, editorial artwork, executive bios, and a direct press contact."
            tr="XRack'i doğru haberleştirmek için gereken her şey — logo ve marka varlıkları, onaylı tanıtım metni, editöryel görseller, yönetici biyografileri ve doğrudan basın iletişimi."
          />
        </p>
        <p class="press-tagline serif-accent">
          <T en="“The model proposes, the runtime executes, the ledger proves.”" tr="“Model önerir, runtime uygular, defter kanıtlar.”" />
        </p>
        <div class="hero-cta">
          <a class="btn-primary" href={`mailto:${pressEmail}`}>
            <T en="Media contact" tr="Basın iletişimi" />
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
          <a class="btn-ghost" href={logo} download="xrack-logo.png">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
            <T en="Download logo" tr="Logoyu indir" />
          </a>
        </div>
      </div>

      <div class="brand-stage reveal-on-view" aria-hidden="true">
        <div class="brand-stage__halo"></div>
        <div class="brand-stage__ring"></div>
        <div class="brand-stage__ring brand-stage__ring--inner"></div>
        <img class="brand-stage__img" src={mascot} alt="" width="1254" height="1254" loading="eager" />
      </div>
    </div>
  </section>

  <div class="wrap press">
    <!-- Fast facts -->
    <section class="press-section reveal-on-view">
      <span class="eyebrow-strong"><T en="Fast facts" tr="Hızlı bilgiler" /></span>
      <div class="facts-grid">
        {
          facts.map((f) => (
            <div class="fact">
              <span class="fact__k"><T en={f.k.en} tr={f.k.tr} /></span>
              <span class="fact__v">
                {f.url ? (
                  <a href={f.url} target={f.url.startsWith("http") ? "_blank" : undefined} rel={f.url.startsWith("http") ? "noopener" : undefined}>
                    <span data-lang-content="en">{f.v.en}</span>
                    <span data-lang-content="tr">{f.v.tr}</span>
                  </a>
                ) : (
                  <>
                    <span data-lang-content="en">{f.v.en}</span>
                    <span data-lang-content="tr">{f.v.tr}</span>
                  </>
                )}
              </span>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Boilerplate -->
    <section class="press-section reveal-on-view">
      <span class="eyebrow-strong"><T en="Boilerplate" tr="Tanıtım metni" /></span>
      <p class="section-note"><T en="Approved copy — quote verbatim. Tap copy to grab the current language." tr="Onaylı metin — birebir alıntılayın. Kopyala'ya dokunarak seçili dili alın." /></p>
      <div class="boiler-grid">
        {
          boilers.map((b) => (
            <article class="boiler card-chrome" data-en={b.en} data-tr={b.tr}>
              <header class="boiler__head">
                <span class="tag-mono"><T en={b.tag.en} tr={b.tag.tr} /></span>
                <button class="boiler__copy" type="button" aria-label="Copy">
                  <svg class="i-copy" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="12" height="12" rx="2"/><path d="M5 15V5a2 2 0 0 1 2-2h10"/></svg>
                  <svg class="i-done" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                  <span><T en="Copy" tr="Kopyala" /></span>
                </button>
              </header>
              <p>
                <span data-lang-content="en">{b.en}</span>
                <span data-lang-content="tr">{b.tr}</span>
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Brand assets -->
    <section class="press-section reveal-on-view">
      <span class="eyebrow-strong"><T en="Brand assets" tr="Marka varlıkları" /></span>
      <p class="section-note">
        <T
          en="Keep clear space around the mark. Don't stretch, recolor, or add effects."
          tr="Logonun çevresinde boşluk bırakın. Germeyin, rengini değiştirmeyin, efekt eklemeyin."
        />
      </p>
      <div class="lockup-row">
        <div class="swatch swatch--dark">
          <img src={logo} alt="XRack logo on dark" />
          <span class="tag-mono">On dark</span>
        </div>
        <div class="swatch swatch--light">
          <img src={logo} alt="XRack logo on light" />
          <span class="tag-mono">On light</span>
        </div>
        <div class="swatch swatch--word">
          <span class="swatch__wordmark"><span class="brand-x">X</span>Rack</span>
          <span class="tag-mono">Wordmark</span>
        </div>
      </div>
      <div class="dl-grid">
        {
          downloads.map((d) => (
            <a class="card-chrome dl" href={d.src} download={d.dl}>
              <div class={`dl__preview dl__preview--${d.tone}`}>
                <img src={d.src} alt="" loading="lazy" />
              </div>
              <div class="dl__foot">
                <div class="dl__meta">
                  <span class="dl__name"><T en={d.name.en} tr={d.name.tr} /></span>
                  <span class="dl__spec">{d.meta}</span>
                </div>
                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12"/><path d="m7 10 5 5 5-5"/><path d="M5 21h14"/></svg>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Editorial artwork -->
    <section class="press-section reveal-on-view">
      <span class="eyebrow-strong"><T en="Editorial artwork" tr="Editöryel görseller" /></span>
      <p class="section-note"><T en="Themed brand illustrations, free to use alongside coverage. Click to open full size." tr="Temalı marka illüstrasyonları; haberlerinizde kullanmakta özgürsünüz. Tam boyut için tıklayın." /></p>
      <div class="gallery">
        {
          imagery.map((s) => (
            <a class="gcard" href={href(`press/screens/${s.f}.png`)} target="_blank" rel="noopener">
              <img src={href(`press/screens/${s.f}.png`)} alt={s.en} loading="lazy" width="1360" height="768" />
              <span class="gcard__cap">
                <T en={s.en} tr={s.tr} />
                <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
              </span>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Executives -->
    <section class="press-section reveal-on-view">
      <span class="eyebrow-strong"><T en="Executives" tr="Yöneticiler" /></span>
      <div class="execs-grid">
        {
          execs.map((a) => (
            <article class="card-chrome exec">
              <div class="exec__top">
                <span class="exec__avatar" aria-hidden="true">{initials(a.name)}</span>
                <div>
                  <h2 class="exec__name">{a.name}</h2>
                  <p class="exec__role">
                    <span data-lang-content="en">{a.roleEn}</span>
                    <span data-lang-content="tr">{a.roleTr}</span>
                  </p>
                </div>
              </div>
              <p class="exec__bio">
                <span data-lang-content="en">{a.bioEn}</span>
                <span data-lang-content="tr">{a.bioTr}</span>
              </p>
              <div class="exec__links">
                <a class="exec__profile" href={href(`authors/${a.slug}`)}><T en="Full profile" tr="Tam profil" /> <span aria-hidden="true">&rarr;</span></a>
                {a.sameAs
                  .filter((u) => !u.includes("xrack.io"))
                  .map((u) => (
                    <a class="exec__social" href={u} target="_blank" rel="noopener" aria-label={socialLabel(u)}>
                      {u.includes("linkedin") ? (
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true" set:html={LINKEDIN_SVG} />
                      ) : u.includes("github") ? (
                        <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true" set:html={GITHUB_SVG} />
                      ) : (
                        <span>{socialLabel(u)}</span>
                      )}
                    </a>
                  ))}
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Contact -->
    <section class="press-section reveal-on-view">
      <div class="contact-card glass">
        <div class="contact-card__glow"></div>
        <span class="eyebrow"><T en="Media contact" tr="Basın iletişimi" /></span>
        <p class="contact-card__lead">
          <T en="For interviews, high-resolution assets, or fact-checks, reach us directly:" tr="Röportaj, yüksek çözünürlüklü görsel veya doğrulama için doğrudan bize ulaşın:" />
        </p>
        <a class="contact-card__mail" href={`mailto:${pressEmail}`}>{pressEmail}</a>
        <div class="contact-card__cta">
          <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener"><T en="Book a Demo" tr="Demo Planla" /></a>
          <a class="btn-ghost" href={SOCIAL.linkedin} target="_blank" rel="noopener">LinkedIn</a>
        </div>
      </div>
    </section>

    <div class="press-back">
      <a class="back-link" href={href()}>&larr; <T en="Back to the blog" tr="Bloga dön" /></a>
    </div>
  </div>
</Base>

<style>
  .press-hero { padding: 5rem 0 3rem; }
  .press-hero__grid {
    position: absolute; inset: 0; z-index: -1; pointer-events: none; opacity: 0.6;
    background-image:
      linear-gradient(hsl(var(--border) / 0.55) 1px, transparent 1px),
      linear-gradient(90deg, hsl(var(--border) / 0.55) 1px, transparent 1px);
    background-size: 46px 46px;
    -webkit-mask-image: radial-gradient(ellipse 78% 60% at 50% 0%, #000, transparent 74%);
    mask-image: radial-gradient(ellipse 78% 60% at 50% 0%, #000, transparent 74%);
  }
  .press-hero__grid-wrap { display: grid; grid-template-columns: 1fr; gap: 2.5rem; align-items: center; }
  @media (min-width: 900px) { .press-hero__grid-wrap { grid-template-columns: 1.05fr 0.95fr; gap: 3rem; } }

  .press-hero__copy { display: flex; flex-direction: column; align-items: flex-start; gap: 1.15rem; text-align: left; }
  .press-hero__title { margin: 0; font-size: clamp(2.6rem, 6vw, 4.25rem); }
  .hero-accent {
    background: linear-gradient(100deg, hsl(22 85% 64%), hsl(6 75% 56%) 55%, hsl(348 60% 60%));
    -webkit-background-clip: text; background-clip: text; color: transparent;
  }
  .press-hero__lede { margin: 0; max-width: 34rem; }
  .press-tagline { font-size: 1.12rem; margin: 0; color: hsl(var(--serif-fg)); }
  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: 0.4rem; }
  .hero-cta .btn-primary, .hero-cta .btn-ghost { padding: 0.6rem 1.2rem; font-size: 13px; }

  .brand-stage { position: relative; display: grid; place-items: center; width: 100%; max-width: 400px; aspect-ratio: 1; margin-inline: auto; }
  .brand-stage__halo {
    position: absolute; inset: 6%; border-radius: 50%;
    background: radial-gradient(circle at 50% 42%, hsl(var(--primary) / 0.4), hsl(var(--amber) / 0.14) 45%, transparent 66%);
    filter: blur(30px); animation: haloPulse 7s ease-in-out infinite;
  }
  .brand-stage__ring {
    position: absolute; inset: 4%; border-radius: 50%;
    border: 1px solid hsl(var(--border-strong) / 0.5);
    -webkit-mask-image: linear-gradient(180deg, #000, transparent 85%);
    mask-image: linear-gradient(180deg, #000, transparent 85%);
  }
  .brand-stage__ring--inner { inset: 15%; border-color: hsl(var(--primary) / 0.22); border-style: dashed; }
  .brand-stage__img {
    position: relative; width: 84%; height: auto;
    filter: drop-shadow(0 28px 55px hsl(0 0% 0% / 0.5));
    animation: floaty 8s ease-in-out infinite;
  }
  @keyframes haloPulse { 0%, 100% { opacity: 0.7; transform: scale(1); } 50% { opacity: 1; transform: scale(1.06); } }
  @keyframes floaty { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }

  .press { padding-bottom: 4rem; }
  .press-section { margin-top: 4.5rem; }
  .press-section > .eyebrow-strong { display: inline-flex; margin-bottom: 1.1rem; }
  .section-note { color: hsl(var(--muted-foreground)); font-size: 14px; line-height: 1.6; margin: 0 0 1.5rem; max-width: 46rem; }
  .tag-mono { font-family: var(--font-mono); font-size: 10.5px; letter-spacing: 0.14em; text-transform: uppercase; color: hsl(var(--muted-foreground)); }

  .facts-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 0.9rem; }
  .fact {
    display: flex; flex-direction: column; gap: 0.45rem; padding: 1.15rem 1.3rem;
    border-radius: calc(var(--radius) - 2px); border: 1px solid hsl(var(--border));
    background-image: linear-gradient(180deg, hsl(var(--card-elevated)), hsl(var(--card)));
    box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.04);
    transition: border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }
  .fact:hover { transform: translateY(-2px); border-color: hsl(var(--border-strong)); box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.05), 0 12px 26px -18px hsl(0 0% 0% / 0.7); }
  .fact__k { font-family: var(--font-mono); font-size: 10px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: hsl(var(--primary)); }
  .fact__v { font-size: 14.5px; line-height: 1.5; color: hsl(var(--foreground)); font-weight: 500; }
  .fact__v a { color: hsl(var(--primary-soft)); }
  .fact__v a:hover { color: hsl(var(--primary)); }

  .boiler-grid { display: grid; gap: 1rem; }
