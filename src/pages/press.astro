---
import Base from "../layouts/Base.astro";
import T from "../components/T.astro";
import { href, SITE } from "../lib/site";
import { AUTHORS } from "../lib/authors";

const logo = href("logo.png");
const execs = Object.values(AUTHORS);
const initials = (name: string) => {
  const w = name.split(/\s+/).filter(Boolean);
  return ((w[0]?.[0] ?? "") + (w.length > 1 ? (w[w.length - 1][0] ?? "") : "")).toUpperCase();
};
const pressEmail = "dogandursun@xrack.io";

const facts = [
  { label: { en: "Company", tr: "Şirket" }, value: "XRack Technologies" },
  {
    label: { en: "Category", tr: "Kategori" },
    value: {
      en: "Sovereign cognitive runtime for regulated enterprise AI",
      tr: "Regüle kurumsal yapay zekâ için bağımsız bilişsel çalışma zamanı",
    },
  },
  {
    label: { en: "Deployment", tr: "Dağıtım" },
    value: {
      en: "Self-hosted appliance, inside your own perimeter",
      tr: "Kendi çevrenizde çalışan, kendi sunucunuzda barındırılan uygulama",
    },
  },
  { label: { en: "Website", tr: "Web sitesi" }, value: "xrack.io", url: SITE.homepage },
  { label: { en: "Blog", tr: "Blog" }, value: "blog.xrack.io", url: href() },
  { label: { en: "Press contact", tr: "Basın iletişimi" }, value: pressEmail, url: `mailto:${pressEmail}` },
];
---

<Base title="Press & Media Kit" description="Brand assets, boilerplate, bios, and press contact for XRack Technologies.">
  <section class="hero" style="padding-bottom:1rem;">
    <div class="wrap section-head">
      <span class="eyebrow-strong"><T en="Press" tr="Basın" /></span>
      <h1 class="display-title"><T en="Press & media kit" tr="Basın ve medya kiti" /></h1>
      <p class="lede">
        <T
          en="Everything you need to write about XRack: logo, approved boilerplate, executive bios, fast facts, and a press contact."
          tr="XRack hakkında yazmak için gereken her şey: logo, onaylı tanıtım metni, yönetici biyografileri, hızlı bilgiler ve basın iletişimi."
        />
      </p>
    </div>
  </section>

  <div class="wrap wrap--narrow press">
    <!-- Fast facts -->
    <section class="press-block">
      <h2 class="press-h"><T en="Fast facts" tr="Hızlı bilgiler" /></h2>
      <dl class="facts">
        {
          facts.map((f) => (
            <div class="facts__row">
              <dt><T en={f.label.en} tr={f.label.tr} /></dt>
              <dd>
                {typeof f.value === "string" ? (
                  f.url ? <a href={f.url}>{f.value}</a> : f.value
                ) : (
                  <>
                    <span data-lang-content="en">{f.value.en}</span>
                    <span data-lang-content="tr">{f.value.tr}</span>
                  </>
                )}
              </dd>
            </div>
          ))
        }
      </dl>
    </section>

    <!-- Brand assets -->
    <section class="press-block">
      <h2 class="press-h"><T en="Brand assets" tr="Marka varlıkları" /></h2>
      <div class="assets">
        <div class="asset">
          <div class="asset__swatch asset__swatch--dark"><img src={logo} alt="XRack logo on dark" /></div>
          <div class="asset__swatch asset__swatch--light"><img src={logo} alt="XRack logo on light" /></div>
        </div>
        <a class="btn-primary" href={logo} download="xrack-logo.png">
          <T en="Download logo (PNG)" tr="Logoyu indir (PNG)" />
        </a>
      </div>
      <p class="press-note">
        <T
          en="Please keep clear space around the mark and do not stretch, recolor, or add effects to it."
          tr="Lütfen logonun çevresinde boşluk bırakın; germeyin, rengini değiştirmeyin ve efekt eklemeyin."
        />
      </p>
    </section>

    <!-- Boilerplate -->
    <section class="press-block">
      <h2 class="press-h"><T en="Boilerplate" tr="Tanıtım metni" /></h2>
      <p class="press-sub"><T en="Short" tr="Kısa" /></p>
      <blockquote class="boiler">
        <span data-lang-content="en">
          XRack Technologies builds a sovereign cognitive runtime for regulated enterprise AI. It turns
          agentic systems from opaque black boxes into auditable glass boxes: agents that remember, act,
          verify, and prove every decision, running as a self-hosted appliance inside the customer's own
          perimeter, on their own model, with their own audit trail.
        </span>
        <span data-lang-content="tr">
          XRack Technologies, regüle kurumsal yapay zekâ için bağımsız bir bilişsel çalışma zamanı
          geliştirir. Agentic sistemleri opak kara kutulardan denetlenebilir cam kutulara dönüştürür:
          hatırlayan, eyleme geçen, doğrulayan ve verdiği her kararı kanıtlayan ajanlar; müşterinin kendi
          çevresinde, kendi modeliyle ve kendi denetim kaydıyla çalışan, kendi sunucusunda barındırılan bir
          uygulama olarak.
        </span>
      </blockquote>
      <p class="press-sub"><T en="Long" tr="Uzun" /></p>
      <blockquote class="boiler">
        <span data-lang-content="en">
          Free-form prompt loops drift, and when they fail you cannot say why — so regulated organizations
          can't put them in production. XRack replaces the open-ended loop with a deterministic cognitive
          cycle (observe → reason → plan → act → verify → learn) and an immutable ledger: every step an
          agent takes is traced, every decision carries its own evidence, and every grant of authority is
          scoped and expiring. The system fails closed by default. It spans four planes — the Harness (a
          single reasoning agent), the Grid (an accountable organization of agents), Federation (grids kept
          in sync across a portfolio), and Embodiment (the same audited cognition extended to physical
          systems) — and ships as an appliance customers run entirely within their own perimeter.
        </span>
        <span data-lang-content="tr">
          Serbest biçimli prompt döngüleri savrulur ve hata verdiklerinde nedenini söyleyemezsiniz; bu yüzden
          regüle kurumlar onları canlıya alamaz. XRack, bu açık uçlu döngünün yerine deterministik bir
          bilişsel döngü (gözlemle → akıl yürüt → planla → eyleme geç → doğrula → öğren) ve değiştirilemez bir
          defter koyar: bir ajanın attığı her adım izlenir, her karar kendi kanıtını taşır ve her yetki
          kapsamlı ve sürelidir. Sistem varsayılan olarak kapalı başlar. Dört düzleme yayılır — Harness (tek
          bir akıl yürütme ajanı), Grid (hesap verebilir bir ajan organizasyonu), Federation (bir portföy
          boyunca eşitlenen gridler) ve Embodiment (aynı denetlenen bilişin fiziksel sistemlere taşınması) —
          ve müşterilerin tamamen kendi çevrelerinde çalıştırdığı bir uygulama olarak gelir.
        </span>
      </blockquote>
    </section>

    <!-- Executive bios -->
    <section class="press-block">
      <h2 class="press-h"><T en="Executives" tr="Yöneticiler" /></h2>
      {
        execs.map((a) => (
          <div class="bio">
            <span class="bio__avatar" aria-hidden="true">{initials(a.name)}</span>
            <div class="bio__body">
              <h3 class="bio__name">{a.name}</h3>
              <p class="bio__role">{a.role}</p>
              <p class="bio__text">
                <span data-lang-content="en">{a.bioEn}</span>
                <span data-lang-content="tr">{a.bioTr}</span>
              </p>
              <div class="bio__links">
                <a href={href(`authors/${a.slug}`)}><T en="Full profile" tr="Tam profil" /></a>
                {a.sameAs.map((u) => (
                  <a href={u} target="_blank" rel="noopener">
                    {u.replace(/^https?:\/\/(www\.)?/, "").split("/")[0]}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))
      }
    </section>

    <!-- Contact -->
    <section class="press-block">
      <h2 class="press-h"><T en="Media contact" tr="Basın iletişimi" /></h2>
      <p>
        <T en="For interviews, assets, or fact-checks:" tr="Röportaj, görsel veya doğrulama için:" />
        {" "}
        <a href={`mailto:${pressEmail}`}>{pressEmail}</a>
      </p>
    </section>

    <div style="margin-top:2.5rem;">
      <a class="back-link" href={href()}>&larr; <T en="All posts" tr="Tüm yazılar" /></a>
    </div>
  </div>
</Base>

<style>
  .press { padding-bottom: 2rem; }
  .press-block { margin-top: 2.75rem; }
  .press-h {
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    font-size: 1.5rem;
    margin: 0 0 1.1rem;
  }
  .press-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    margin: 1.25rem 0 0.5rem;
  }
  .facts { margin: 0; display: grid; gap: 0; }
  .facts__row {
    display: grid;
    grid-template-columns: 12rem 1fr;
    gap: 1rem;
    padding: 0.7rem 0;
    border-bottom: 1px solid hsl(var(--border) / 0.6);
  }
  .facts__row dt {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 0.06em;
    color: hsl(var(--muted-foreground));
  }
  .facts__row dd { margin: 0; }
  .assets { display: flex; flex-wrap: wrap; align-items: center; gap: 1.25rem; }
  .asset { display: flex; gap: 0.75rem; }
  .asset__swatch {
    width: 96px;
    height: 96px;
    border-radius: var(--radius);
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid hsl(var(--border));
  }
  .asset__swatch img { width: 60px; height: 60px; }
  .asset__swatch--dark { background: hsl(20 3% 8%); }
  .asset__swatch--light { background: #ffffff; }
  .press-note { color: hsl(var(--muted-foreground)); font-size: 14px; margin-top: 1rem; }
  .boiler {
    margin: 0;
    padding: 1rem 1.25rem;
    border-left: 3px solid hsl(var(--primary));
    background: hsl(var(--card-elevated) / 0.4);
    border-radius: 0 var(--radius) var(--radius) 0;
    line-height: 1.7;
  }
  .bio { display: flex; gap: 1.25rem; margin-bottom: 1.5rem; }
  .bio__avatar {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-display);
    font-weight: 600;
    color: hsl(var(--primary-foreground));
    background-image: linear-gradient(180deg, hsl(var(--primary-soft)), hsl(var(--primary)));
  }
  .bio__name { font-family: var(--font-display); font-weight: 600; font-size: 1.15rem; margin: 0; }
  .bio__role { color: hsl(var(--muted-foreground)); font-size: 13px; margin: 0.2rem 0 0.6rem; }
  .bio__text { margin: 0 0 0.6rem; }
  .bio__links { display: flex; flex-wrap: wrap; gap: 1rem; font-size: 14px; }
  @media (max-width: 520px) {
    .facts__row { grid-template-columns: 1fr; gap: 0.15rem; }
    .bio { flex-direction: column; gap: 0.75rem; }
  }
</style>
