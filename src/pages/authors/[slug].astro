---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import T from "../../components/T.astro";
import { AUTHORS, resolveAuthor, type Author } from "../../lib/authors";
import { href } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return Object.values(AUTHORS).map((author) => ({
    params: { slug: author.slug },
    props: {
      author,
      posts: posts
        .filter((p) => resolveAuthor(p.data.author).slug === author.slug)
        .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
    },
  }));
}

interface Props {
  author: Author;
  posts: Awaited<ReturnType<typeof getCollection<"blog">>>;
}
const { author, posts } = Astro.props as Props;

const nameWords = author.name.split(/\s+/).filter(Boolean);
const initials = (
  (nameWords[0]?.[0] ?? "") + (nameWords.length > 1 ? (nameWords[nameWords.length - 1][0] ?? "") : "")
).toUpperCase();

const abs = (u: string) => (Astro.site ? new URL(u, Astro.site).href : u);
const pageUrl = abs(href(`authors/${author.slug}`));

// Icon markup per destination (inline so the CSP-safe static build needs no assets).
const ICON: Record<string, string> = {
  linkedin:
    '<path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.35V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28zM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.73v20.54C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.73V1.73C24 .77 23.2 0 22.22 0z"/>',
  github:
    '<path d="M12 .3a12 12 0 0 0-3.8 23.4c.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.08-.74.09-.73.09-.73 1.2.09 1.84 1.24 1.84 1.24 1.07 1.83 2.8 1.3 3.49 1 .1-.78.42-1.31.76-1.61-2.67-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 0 1 6.01 0c2.29-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.8 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.69.83.57A12 12 0 0 0 12 .3z"/>',
  globe:
    '<circle cx="12" cy="12" r="9"/><path d="M3 12h18"/><path d="M12 3c2.5 2.5 3.8 5.7 3.8 9s-1.3 6.5-3.8 9c-2.5-2.5-3.8-5.7-3.8-9S9.5 5.5 12 3z"/>',
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3.5 7 8.5 6 8.5-6"/>',
};

type LinkItem = { href: string; label: string; icon: string; external: boolean };
const links: LinkItem[] = author.sameAs.map((u) => {
  const host = u.replace(/^https?:\/\//, "").replace(/^www\./, "").split("/")[0];
  if (host.includes("linkedin")) return { href: u, label: "LinkedIn", icon: "linkedin", external: true };
  if (host.includes("github")) return { href: u, label: "GitHub", icon: "github", external: true };
  return { href: u, label: host, icon: "globe", external: true };
});

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: author.name,
  jobTitle: author.roleEn,
  url: pageUrl,
  ...(author.email ? { email: `mailto:${author.email}` } : {}),
  sameAs: author.sameAs,
  worksFor: { "@type": "Organization", name: "XRack Technologies", url: "https://xrack.io" },
};

const svg = (k: string, size = 15) =>
  `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">${ICON[k]}</svg>`;
const svgSolid = (k: string, size = 15) =>
  `<svg viewBox="0 0 24 24" width="${size}" height="${size}" fill="currentColor" aria-hidden="true">${ICON[k]}</svg>`;
---

<Base title={author.name} description={author.bioEn} jsonLd={jsonLd}>
  <section class="hero author-hero">
    <div class="hero-aura"></div>
    <div class="wrap author-hero__inner reveal-on-view">
      <span class="author-avatar" aria-hidden="true">{initials}</span>

      <span class="eyebrow-strong author-eyebrow">XRack Technologies</span>

      <h1 class="display-title author-name">{author.name}</h1>

      <div class="author-tags">
        <span class="role-chip">
          <span data-lang-content="en">{author.roleEn}</span>
          <span data-lang-content="tr">{author.roleTr}</span>
        </span>
        {author.credentials && <span class="cred-chip">{author.credentials}</span>}
      </div>

      <p class="lede author-bio">
        <span data-lang-content="en">{author.bioEn}</span>
        <span data-lang-content="tr">{author.bioTr}</span>
      </p>

      <div class="author-links">
        {
          links.map((l) => (
            <a
              class="social-link"
              href={l.href}
              target={l.external ? "_blank" : undefined}
              rel={l.external ? "noopener me" : undefined}
              aria-label={l.label}
            >
              <span class="social-link__ico" set:html={svgSolid(l.icon)} />
              <span>{l.label}</span>
            </a>
          ))
        }
        {
          author.email && (
            <a class="social-link" href={`mailto:${author.email}`} aria-label="Email">
              <span class="social-link__ico" set:html={svg("mail")} />
              <span><T en="Email" tr="E-posta" /></span>
            </a>
          )
        }
      </div>
    </div>
  </section>

  <section class="feed author-feed">
    <div class="wrap">
      <div class="feed-head">
        <span class="eyebrow-strong"><T en="Writing" tr="Yazılar" /></span>
        <span class="feed-count">
          {posts.length}
          {" "}
          <T en={posts.length === 1 ? "post" : "posts"} tr="yazı" />
        </span>
      </div>
      {
        posts.length ? (
          <div class="card-grid">
            {posts.map((post) => (
              <PostCard post={post} />
            ))}
          </div>
        ) : (
          <p class="empty">
            <T en="No posts yet." tr="Henüz yazı yok." />
          </p>
        )
      }
      <div class="author-back">
        <a class="back-link" href={href()}>
          &larr; <T en="All posts" tr="Tüm yazılar" />
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .author-hero {
    padding: 5rem 0 2.5rem;
  }
  .author-hero__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .author-avatar {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 92px;
    height: 92px;
    border-radius: 9999px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 2rem;
    letter-spacing: 0.01em;
    color: hsl(var(--primary-foreground));
    background-image: linear-gradient(180deg, hsl(var(--primary-soft)), hsl(var(--primary)));
    box-shadow:
      inset 0 1px 0 hsl(0 0% 100% / 0.22),
      0 0 0 6px hsl(var(--primary) / 0.08),
      0 14px 30px -12px hsl(var(--primary) / 0.7);
  }

  .author-eyebrow {
    margin-top: 0.4rem;
  }

  .author-name {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 3.25rem);
  }

  .author-tags {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
  }
  .role-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.32rem 0.85rem;
    font-size: 12.5px;
    font-weight: 600;
    line-height: 1;
    color: hsl(var(--primary));
    background: hsl(var(--primary) / 0.1);
    box-shadow: inset 0 0 0 1px hsl(var(--primary) / 0.28);
  }
  .cred-chip {
    display: inline-flex;
    align-items: center;
    border-radius: 9999px;
    padding: 0.32rem 0.8rem;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.06em;
    line-height: 1;
    color: hsl(var(--muted-foreground));
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card-elevated) / 0.6);
  }

  .author-bio {
    margin: 0.4rem auto 0;
    max-width: 44rem;
  }

  .author-links {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 0.6rem;
    margin-top: 0.85rem;
  }
  .social-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.95rem;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 500;
    color: hsl(var(--foreground));
    border: 1px solid hsl(var(--border));
    background: hsl(var(--card-elevated));
    box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.04);
    transition:
      color 0.15s ease,
      border-color 0.15s ease,
      background 0.15s ease,
      transform 0.15s ease;
  }
  .social-link:hover {
    color: hsl(var(--primary));
    border-color: hsl(var(--primary) / 0.45);
    background: hsl(var(--card-glass));
    transform: translateY(-1px);
  }
  .social-link__ico {
    display: inline-flex;
    color: hsl(var(--muted-foreground));
    transition: color 0.15s ease;
  }
  .social-link:hover .social-link__ico {
    color: hsl(var(--primary));
  }

  .author-feed {
    padding-top: 1rem;
  }
  .feed-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding-bottom: 1.1rem;
    margin-bottom: 1.75rem;
    border-bottom: 1px solid hsl(var(--border));
  }
  .feed-count {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
  }
  .author-back {
    margin-top: 2.5rem;
  }

  @media (max-width: 640px) {
    .author-hero {
      padding: 3.5rem 0 2rem;
    }
    .author-avatar {
      width: 76px;
      height: 76px;
      font-size: 1.65rem;
    }
  }
</style>
