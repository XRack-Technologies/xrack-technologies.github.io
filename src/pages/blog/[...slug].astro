---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import { href, formatDate, formatDateTr } from "../../lib/site";
import { renderBilingual, readingMinutes, enWordCount } from "../../lib/i18n";
import T from "../../components/T.astro";
import Share from "../../components/Share.astro";
import ShareFab from "../../components/ShareFab.astro";
import Comments from "../../components/Comments.astro";

export async function getStaticPaths() {
  const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
  );
  return posts.flatMap((post, i) => {
    const neighbors = {
      newer: i > 0 ? posts[i - 1] : null,
      older: i < posts.length - 1 ? posts[i + 1] : null,
    };
    const { bilingual } = renderBilingual(post.body ?? "");
    const hasTr = bilingual || !!post.data.title_tr || !!post.data.description_tr;
    const langs = hasTr ? ["en", "tr"] : ["en"];
    return langs.map((lang) => ({
      params: { slug: lang === "tr" ? `${post.id}/tr` : post.id },
      props: { post, lang, ...neighbors },
    }));
  });
}

const { post, lang = "en", newer, older } = Astro.props;
const isTr = lang === "tr";
const { title, description, pubDate, tags, author, cover } = post.data;
const titleTr = post.data.title_tr ?? title;
const descriptionTr = post.data.description_tr ?? description;
const { enHtml, trHtml, bilingual } = renderBilingual(post.body ?? "");
const mins = readingMinutes(post.body ?? "");
const metaDual = !!post.data.title_tr || !!post.data.description_tr;
const hasTr = bilingual || !!post.data.title_tr || !!post.data.description_tr;
const keywords = post.data.keywords ?? tags;
const neighborHasTr = (p: typeof newer) =>
  !!p && (renderBilingual(p.body ?? "").bilingual || !!p.data.title_tr || !!p.data.description_tr);
const newerHasTr = neighborHasTr(newer);
const olderHasTr = neighborHasTr(older);

const abs = (u: string) => (Astro.site ? new URL(u, Astro.site).href : u);
const enUrl = abs(href(`blog/${post.id}/`));
const trUrl = abs(href(`blog/${post.id}/tr/`));
const selfUrl = isTr ? trUrl : enUrl;
const ogImage = (l: "en" | "tr") =>
  cover ? abs(cover) : abs(href(`og/${post.id}${l === "tr" ? "/tr" : ""}.png`));
const image = ogImage(lang as "en" | "tr");
const ogTitle = isTr ? titleTr : title;
const ogDescription = isTr ? descriptionTr : description;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: ogTitle,
  description: ogDescription,
  datePublished: pubDate.toISOString(),
  dateModified: (post.data.updatedDate ?? pubDate).toISOString(),
  author: { "@type": "Person", name: author },
  publisher: { "@type": "Organization", name: "XRack Technologies" },
  keywords: keywords.join(", "),
  articleSection: tags[0],
  inLanguage: isTr ? "tr" : "en",
  wordCount: enWordCount(post.body ?? ""),
  timeRequired: `PT${mins}M`,
  image,
  mainEntityOfPage: selfUrl,
  url: selfUrl,
};
---

<Base
  title={ogTitle}
  description={ogDescription}
  keywords={keywords}
  ogType="article"
  image={image}
  publishedTime={pubDate.toISOString()}
  articleTags={tags}
  showProgress={true}
  jsonLd={jsonLd}
  forceLang={hasTr ? (isTr ? "tr" : "en") : undefined}
  alternates={hasTr ? { en: enUrl, tr: trUrl } : undefined}
>
  <article class="article article--post">
    <Share url={enUrl} urlTr={hasTr ? trUrl : undefined} title={title} titleTr={titleTr} variant="rail" />
    <ShareFab url={enUrl} urlTr={hasTr ? trUrl : undefined} title={title} titleTr={titleTr} />
    <header class="wrap wrap--narrow article-head">
      <div class="post-card__meta" style="justify-content:center;">
        {tags[0] && <span class="pill pill-primary">{tags[0]}</span>}
        <time datetime={pubDate.toISOString()}>
          <span data-lang-content="en">{formatDate(pubDate)}</span>
          <span data-lang-content="tr">{formatDateTr(pubDate)}</span>
        </time>
        <span class="dot">&middot;</span>
        <span><T en={`${mins} min read`} tr={`${mins} dk okuma`} /></span>
      </div>
      <h1 class="display-title">
        {
          metaDual ? (
            <>
              <span data-lang-content="en">{title}</span>
              <span data-lang-content="tr">{titleTr}</span>
            </>
          ) : (
            title
          )
        }
      </h1>
      <p class="article-lead">
        {
          metaDual ? (
            <>
              <span data-lang-content="en">{description}</span>
              <span data-lang-content="tr">{descriptionTr}</span>
            </>
          ) : (
            description
          )
        }
      </p>
      <div class="byline"><T en="by" tr="yazan" /> <b>{author}</b></div>
    </header>

    {
      cover && (
        <figure class="article-cover wrap">
          <img src={cover} alt={title} />
        </figure>
      )
    }

    <div class="wrap wrap--narrow">
      {
        bilingual ? (
          <>
            <div class="prose" data-lang-content="en" set:html={enHtml} />
            <div class="prose" data-lang-content="tr" set:html={trHtml} />
          </>
        ) : (
          <div class="prose" set:html={enHtml} />
        )
      }
    </div>

    <div class="wrap wrap--narrow">
      <Share url={enUrl} urlTr={hasTr ? trUrl : undefined} title={title} titleTr={titleTr} />
    </div>

    <div class="wrap wrap--narrow article-foot">
      <div class="tag-list">
        {tags.map((tag) => <a class="pill" href={href(`tags/${tag}`)}>{tag}</a>)}
      </div>
      <a class="back-link" href={href()}>&larr; <T en="All posts" tr="Tüm yazılar" /></a>
    </div>

    <Comments term={post.id} url={selfUrl} title={ogTitle} />

    {
      (newer || older) && (
        <nav class="wrap wrap--narrow post-nav" aria-label="More posts">
          {newer ? (
            <a class="post-nav__item post-nav__item--prev" href={href(`blog/${newer.id}`)} data-href-tr={newerHasTr ? href(`blog/${newer.id}/tr`) : undefined}>
              <span class="post-nav__dir"><T en="Newer" tr="Daha yeni" /></span>
              <span class="post-nav__title">
                <span data-lang-content="en">{newer.data.title}</span>
                <span data-lang-content="tr">{newer.data.title_tr ?? newer.data.title}</span>
              </span>
            </a>
          ) : (
            <span />
          )}
          {older ? (
            <a class="post-nav__item post-nav__item--next" href={href(`blog/${older.id}`)} data-href-tr={olderHasTr ? href(`blog/${older.id}/tr`) : undefined}>
              <span class="post-nav__dir"><T en="Older" tr="Daha eski" /></span>
              <span class="post-nav__title">
                <span data-lang-content="en">{older.data.title}</span>
                <span data-lang-content="tr">{older.data.title_tr ?? older.data.title}</span>
              </span>
            </a>
          ) : (
            <span />
          )}
        </nav>
      )
    }
  </article>
</Base>
