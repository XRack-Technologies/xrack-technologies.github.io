---
import { getCollection } from "astro:content";
import Base from "../../layouts/Base.astro";
import PostCard from "../../components/PostCard.astro";
import T from "../../components/T.astro";
import { NAV } from "../../lib/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tags = [...new Set([...NAV.map((n) => n.tag), ...posts.flatMap((p) => p.data.tags)])];
  return tags.map((tag) => {
    const navItem = NAV.find((n) => n.tag === tag);
    return {
      params: { tag },
      props: {
        tag,
        label: navItem?.label ?? tag,
        labelTr: navItem?.label_tr ?? tag,
        posts: posts
          .filter((p) => p.data.tags.includes(tag))
          .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()),
      },
    };
  });
}

const { label, labelTr, posts } = Astro.props;
const count = posts.length;
---

<Base title={label}>
  <section class="hero" style="padding-bottom:1rem;">
    <div class="wrap section-head">
      <span class="eyebrow-strong"><T en="Category" tr="Kategori" /></span>
      <h1 class="display-title"><T en={label} tr={labelTr} /></h1>
      <p class="lede">
        <T en={`${count} ${count === 1 ? "post" : "posts"}`} tr={`${count} yazı`} />
      </p>
    </div>
  </section>

  <section class="feed" style="padding-top:1.5rem;">
    <div class="wrap">
      {
        count ? (
          <div class="card-grid">{posts.map((post) => <PostCard post={post} />)}</div>
        ) : (
          <p class="empty">
            <T en="No posts in this category yet — check back soon." tr="Bu kategoride henüz yazı yok — yakında tekrar bakın." />
          </p>
        )
      }
    </div>
  </section>
</Base>
