---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import { SITE } from "../lib/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);
---

<Base>
  <section class="hero">
    <div class="hero-aura"></div>
    <div class="wrap hero-inner">
      <span class="status-chip"><span class="dot"></span> The XRack Journal</span>
      <h1 class="display-title">
        Notes from the <span class="serif-accent">observable</span> harness
      </h1>
      <p class="lede">{SITE.description}</p>
    </div>
  </section>

  <section class="feed">
    <div class="wrap">
      {
        posts.length ? (
          <div class="card-grid">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        ) : (
          <p class="empty">No posts yet — the first one is on its way.</p>
        )
      }
    </div>
  </section>
</Base>
