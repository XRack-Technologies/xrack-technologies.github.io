---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import PostCard from "../components/PostCard.astro";
import Newsletter from "../components/Newsletter.astro";
import T from "../components/T.astro";
import { SITE, SITE_TR, NAV } from "../lib/site";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const tagCounts = new Map<string, number>();
for (const p of posts) for (const t of p.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
const tagList = [...tagCounts.keys()].sort();
const labelFor = (t: string) => NAV.find((n) => n.tag === t)?.label ?? t;
const labelTrFor = (t: string) => NAV.find((n) => n.tag === t)?.label_tr ?? t;
---

<Base>
  <section class="hero">
    <div class="hero-aura"></div>
    <div class="wrap hero-inner">
      <span class="status-chip">
        <span class="dot"></span> <T en="The XRack Journal" tr="XRack Günlüğü" />
      </span>
      <h1 class="display-title">
        <span data-lang-content="en">Notes from the <span class="serif-accent">observable</span> harness.</span>
        <span data-lang-content="tr">Gözlemlenebilir <span class="serif-accent">harness</span> üzerine notlar.</span>
      </h1>
      <p class="lede">
        <span data-lang-content="en">{SITE.description}</span>
        <span data-lang-content="tr">{SITE_TR.description}</span>
      </p>
    </div>
  </section>

  <section class="feed">
    <div class="wrap">
      {posts.length === 0 ? (
      <p class="empty">
        <T en="No posts yet; the first one is on its way." tr="Henüz bir yazı yok; ilki yakında yayında olacak." />
      </p>
      ) : (
      <>
      <div class="controls">
        <label class="search">
          <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m20 20-3.5-3.5"/></svg>
          <input
            id="searchInput"
            type="search"
            autocomplete="off"
            aria-label="Search posts"
            data-ph-en="Search posts…"
            data-ph-tr="Yazılarda ara…"
            placeholder="Search posts…"
          />
        </label>
        <div class="sort-group" role="group" aria-label="Sort">
          <button class="sort-opt is-active" type="button" aria-pressed="true" data-sort="newest"><T en="Newest" tr="En yeni" /></button>
          <button class="sort-opt" type="button" aria-pressed="false" data-sort="oldest"><T en="Oldest" tr="En eski" /></button>
        </div>
      </div>

      <div class="filter-chips" id="filterChips">
        <button class="filter-chip is-active" type="button" aria-pressed="true" data-tag="all">
          <T en="All" tr="Tümü" /> <span class="c">{posts.length}</span>
        </button>
        {
          tagList.map((t) => (
            <button class="filter-chip" type="button" aria-pressed="false" data-tag={t}>
              <T en={labelFor(t)} tr={labelTrFor(t)} /> <span class="c">{tagCounts.get(t)}</span>
            </button>
          ))
        }
      </div>

      <div class="card-grid" id="postGrid">
        {posts.map((post) => <PostCard post={post} />)}
      </div>
      <div class="load-more">
        <button id="loadMore" class="btn-ghost" type="button" hidden>
          <T en="Load more" tr="Daha fazla" />
        </button>
      </div>
      <p class="empty" id="feedEmpty" role="status" aria-live="polite" hidden>
        <T en="No posts match your search." tr="Eşleşen yazı bulunamadı." />
      </p>
      </>
      )}
    </div>
  </section>

  <section class="wrap" style="padding-bottom:5rem;">
    <Newsletter />
  </section>

  <script>
    const grid = document.getElementById("postGrid");
    const searchInput = document.getElementById("searchInput") as HTMLInputElement | null;
    const emptyEl = document.getElementById("feedEmpty");
    const loadMore = document.getElementById("loadMore");
    const cards = Array.from(document.querySelectorAll<HTMLElement>(".post-card"));
    const chips = Array.from(document.querySelectorAll<HTMLElement>(".filter-chip"));
    const sortOpts = Array.from(document.querySelectorAll<HTMLElement>(".sort-opt"));

    if (grid && searchInput && emptyEl) {
      const PAGE = 9;
      let activeTag = "all";
      let sortMode = "newest";
      let visible = PAGE;

      const apply = () => {
        const q = searchInput.value.trim().toLowerCase();
        const shown = cards.filter((c) => {
          const okTag = activeTag === "all" || (c.dataset.tags ?? "").split(" ").includes(activeTag);
          const okText = !q || (c.dataset.search ?? "").includes(q);
          return okTag && okText;
        });
        shown.sort((a, b) => {
          const da = a.dataset.date ?? "";
          const db = b.dataset.date ?? "";
          return sortMode === "oldest" ? da.localeCompare(db) : db.localeCompare(da);
        });
        cards.forEach((c) => { c.style.display = "none"; });
        shown.forEach((c, i) => {
          if (i < visible) { c.style.display = ""; c.classList.add("is-visible"); }
          grid.appendChild(c);
        });
        emptyEl.hidden = shown.length > 0;
        if (loadMore) loadMore.hidden = shown.length <= visible;
      };

      const reset = () => { visible = PAGE; };

      searchInput.addEventListener("input", () => { reset(); apply(); });
      const setActive = (group: HTMLElement[], current: HTMLElement) => {
        group.forEach((el) => {
          const on = el === current;
          el.classList.toggle("is-active", on);
          el.setAttribute("aria-pressed", on ? "true" : "false");
        });
      };
      chips.forEach((ch) =>
        ch.addEventListener("click", () => {
          activeTag = ch.dataset.tag ?? "all";
          setActive(chips, ch);
          reset();
          apply();
        }),
      );
      sortOpts.forEach((s) =>
        s.addEventListener("click", () => {
          sortMode = s.dataset.sort ?? "newest";
          setActive(sortOpts, s);
          reset();
          apply();
        }),
      );
      loadMore?.addEventListener("click", () => { visible += PAGE; apply(); });
      const q0 = new URLSearchParams(location.search).get("q");
      if (q0) searchInput.value = q0;
      apply();
    }
  </script>
</Base>
