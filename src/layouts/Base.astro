---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { SITE, NAV, href } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
}

// Which categories actually have published posts — used to gray out empty ones.
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const activeTags = new Set(allPosts.flatMap((p) => p.data.tags));
const hasPosts = (tag: string) => activeTags.has(tag);
const { title, description = SITE.description } = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const path = Astro.url.pathname.replace(/\/$/, "");
const logo = href("logo.png");
const isActive = (tag: string) => path === href(`tags/${tag}`).replace(/\/$/, "");
const homeActive = path === href().replace(/\/$/, "");
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Apply the remembered language before paint (no flash of the wrong language).
      try { document.documentElement.dataset.lang = localStorage.getItem("xrack-blog-lang") || "en"; }
      catch (e) { document.documentElement.dataset.lang = "en"; }
    </script>
    <link rel="icon" type="image/png" href={logo} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={logo} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=Geist:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header id="topbar" class="topbar-shell">
      <div class="topbar-inner">
        <a class="brand" href={href()}>
          <span class="brand-mark"><img src={logo} alt="" /></span>
          <span class="brand-name">
            <b>XRack</b>
            <span>Blog · Sovereign Cognitive Runtime</span>
          </span>
        </a>

        <nav class="nav-rail nav-desktop" aria-label="Primary">
          <a class="nav-link" href={href()} aria-current={homeActive ? "page" : undefined}>All</a>
          {
            NAV.map((item) =>
              hasPosts(item.tag) ? (
                <a class="nav-link" href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}>{item.label}</a>
              ) : (
                <span class="nav-link nav-link--empty" aria-disabled="true" title="No posts yet">{item.label}</span>
              ),
            )
          }
        </nav>

        <div class="topbar-actions nav-desktop">
          <div class="lang-toggle" role="group" aria-label="Language">
            <button class="lang-opt" type="button" data-lang-opt="en">EN</button>
            <button class="lang-opt" type="button" data-lang-opt="tr">TR</button>
          </div>
          <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">
            xrack.io
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
          <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener">
            Book a Demo
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <button class="menu-btn" id="menuBtn" type="button" aria-label="Open menu" aria-controls="mobileMenu" aria-expanded="false">
          <svg class="i-open" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
          <svg class="i-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12"/><path d="M18 6 6 18"/></svg>
        </button>
      </div>

      <div class="mobile-menu" id="mobileMenu">
        <div class="mobile-menu__inner">
          <nav class="mobile-nav" aria-label="Mobile">
            <a href={href()} aria-current={homeActive ? "page" : undefined}>All</a>
            {
              NAV.map((item) =>
                hasPosts(item.tag) ? (
                  <a href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}>{item.label}</a>
                ) : (
                  <span class="is-empty" aria-disabled="true">{item.label}</span>
                ),
              )
            }
          </nav>
          <div class="lang-toggle lang-toggle--mobile" role="group" aria-label="Language">
            <button class="lang-opt" type="button" data-lang-opt="en">EN</button>
            <button class="lang-opt" type="button" data-lang-opt="tr">TR</button>
          </div>
          <div class="mobile-actions">
            <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">xrack.io</a>
            <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener">Book a Demo</a>
          </div>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div class="site-foot-top">
          <div class="foot-about">
            <a class="brand" href={href()}>
              <span class="brand-mark"><img src={logo} alt="" /></span>
              <span class="brand-name">
                <b>XRack</b>
                <span>Sovereign Cognitive Runtime</span>
              </span>
            </a>
            <p>{SITE.description}</p>
          </div>

          <div class="foot-cols">
            <div>
              <h4 class="eyebrow">Blog</h4>
              <ul>
                <li><a href={href()}>All</a></li>
                {
                  NAV.map((item) => (
                    <li>
                      {hasPosts(item.tag) ? (
                        <a href={href(`tags/${item.tag}`)}>{item.label}</a>
                      ) : (
                        <span class="is-empty" title="No posts yet">{item.label}</span>
                      )}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h4 class="eyebrow">XRack</h4>
              <ul>
                <li><a href={SITE.homepage} target="_blank" rel="noopener">Product</a></li>
                <li><a href={`${SITE.homepage}/demos.html`} target="_blank" rel="noopener">Demos</a></li>
                <li><a href={href("about")}>About</a></li>
              </ul>
            </div>
            <div>
              <h4 class="eyebrow">Contact</h4>
              <ul>
                <li><a href="mailto:dogandursun@xrack.io">dogandursun@xrack.io</a></li>
                <li><a href={SITE.cta} target="_blank" rel="noopener">Book a Demo</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="site-foot-bottom">
          <div>&copy; {year} XRack Technologies. All rights reserved.</div>
          <div>Built with cognition.</div>
        </div>
      </div>
    </footer>

    <script>
      // Header elevation on scroll
      const bar = document.getElementById("topbar");
      const onScroll = () => bar?.classList.toggle("is-scrolled", window.scrollY > 8);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // Mobile menu
      const menuBtn = document.getElementById("menuBtn");
      const menu = document.getElementById("mobileMenu");
      const setMenu = (open) => {
        menu?.classList.toggle("open", open);
        menuBtn?.setAttribute("aria-expanded", open ? "true" : "false");
        bar?.classList.toggle("menu-open", open);
      };
      menuBtn?.addEventListener("click", () =>
        setMenu(menuBtn.getAttribute("aria-expanded") !== "true"),
      );
      menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") setMenu(false); });
      window.addEventListener("resize", () => { if (window.innerWidth > 900) setMenu(false); });

      // Language switch (EN/TR) — remembers the choice in localStorage
      const LANG_KEY = "xrack-blog-lang";
      const langButtons = document.querySelectorAll(".lang-opt");
      const applyLang = (lang) => {
        const l = lang === "tr" ? "tr" : "en";
        document.documentElement.dataset.lang = l;
        try { localStorage.setItem(LANG_KEY, l); } catch (e) {}
        langButtons.forEach((b) =>
          b.classList.toggle("is-active", b.getAttribute("data-lang-opt") === l),
        );
      };
      langButtons.forEach((b) =>
        b.addEventListener("click", () => applyLang(b.getAttribute("data-lang-opt"))),
      );
      applyLang(document.documentElement.dataset.lang || "en");

      // Scroll-reveal
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
      );
      document.querySelectorAll(".reveal-on-view").forEach((el) => io.observe(el));
    </script>
  </body>
</html>
