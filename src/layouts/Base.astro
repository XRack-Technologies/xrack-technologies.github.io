---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { SITE, SITE_TR, NAV, href } from "../lib/site";
import T from "../components/T.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string[];
  ogType?: string;
  publishedTime?: string;
  articleTags?: string[];
  showProgress?: boolean;
  jsonLd?: unknown;
  image?: string;
}

// Which categories actually have published posts — used to gray out empty ones.
const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const activeTags = new Set(allPosts.flatMap((p) => p.data.tags));
const hasPosts = (tag: string) => activeTags.has(tag);
const {
  title,
  description = SITE.description,
  keywords = [],
  ogType = "website",
  publishedTime,
  articleTags = [],
  showProgress = false,
  jsonLd,
  image,
} = Astro.props;
const pageTitle = title ? `${title} — ${SITE.title}` : `${SITE.title} — ${SITE.tagline}`;
const path = Astro.url.pathname.replace(/\/$/, "");
const logo = href("logo.png");
const isActive = (tag: string) => path === href(`tags/${tag}`).replace(/\/$/, "");
const homeActive = path === href().replace(/\/$/, "");
const aboutActive = path === href("about").replace(/\/$/, "");
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const ogImage = image ?? (Astro.site ? new URL(logo, Astro.site).href : logo);
const year = new Date().getFullYear();
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <script is:inline>
      // Apply the remembered language before paint (no flash of the wrong language).
      try {
        var _l = localStorage.getItem("xrack-blog-lang") || "en";
        document.documentElement.dataset.lang = _l;
        document.documentElement.lang = _l;
      } catch (e) {
        document.documentElement.dataset.lang = "en";
      }
    </script>
    <link rel="icon" type="image/png" href={logo} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {keywords.length > 0 && <meta name="keywords" content={keywords.join(", ")} />}
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={href("rss.xml")} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && <meta property="article:author" content={SITE.author} />}
    {articleTags.map((t) => <meta property="article:tag" content={t} />)}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,500;12..96,600;12..96,700&family=Geist:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a class="skip-link" href="#main"><T en="Skip to content" tr="İçeriğe geç" /></a>
    {showProgress && <div class="read-progress" id="readProgress" aria-hidden="true"></div>}
    <header id="topbar" class="topbar-shell">
      <div class="topbar-inner">
        <a class="brand" href={href()}>
          <span class="brand-mark"><img src={logo} alt="" /></span>
          <span class="brand-name">
            <b>XRack</b>
            <span><T en="Blog · Sovereign Cognitive Runtime" tr="Blog · Bağımsız Bilişsel Runtime" /></span>
          </span>
        </a>

        <nav class="nav-rail nav-desktop" aria-label="Primary">
          <a class="nav-link" href={href()} aria-current={homeActive ? "page" : undefined}><T en="All" tr="Tümü" /></a>
          {
            NAV.map((item) =>
              hasPosts(item.tag) ? (
                <a class="nav-link" href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}><T en={item.label} tr={item.label_tr} /></a>
              ) : (
                <span class="nav-link nav-link--empty" aria-disabled="true"><T en={item.label} tr={item.label_tr} /></span>
              ),
            )
          }
          <a class="nav-link" href={href("about")} aria-current={aboutActive ? "page" : undefined}><T en="About" tr="Hakkında" /></a>
        </nav>

        <div class="topbar-actions nav-desktop">
          <div class="lang-toggle" role="group" aria-label="Language">
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="en">EN</button>
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="tr">TR</button>
          </div>
          <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">
            xrack.io
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
          <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener">
            <T en="Book a Demo" tr="Demo Planla" />
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <button class="menu-btn" id="menuBtn" type="button" aria-label="Open menu" aria-controls="mobileMenu" aria-expanded="false">
          <svg class="i-open" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
          <svg class="i-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12"/><path d="M18 6 6 18"/></svg>
        </button>
      </div>

      <div class="mobile-menu" id="mobileMenu">
        <div class="mobile-menu__inner">
          <nav class="mobile-nav" aria-label="Mobile">
            <a href={href()} aria-current={homeActive ? "page" : undefined}><T en="All" tr="Tümü" /></a>
            {
              NAV.map((item) =>
                hasPosts(item.tag) ? (
                  <a href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}><T en={item.label} tr={item.label_tr} /></a>
                ) : (
                  <span class="is-empty" aria-disabled="true"><T en={item.label} tr={item.label_tr} /></span>
                ),
              )
            }
            <a href={href("about")} aria-current={aboutActive ? "page" : undefined}><T en="About" tr="Hakkında" /></a>
          </nav>
          <div class="lang-toggle lang-toggle--mobile" role="group" aria-label="Language">
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="en">EN</button>
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="tr">TR</button>
          </div>
          <div class="mobile-actions">
            <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">xrack.io</a>
            <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener"><T en="Book a Demo" tr="Demo Planla" /></a>
          </div>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div class="site-foot-top">
          <div class="foot-about">
            <a class="brand" href={href()}>
              <span class="brand-mark"><img src={logo} alt="" /></span>
              <span class="brand-name">
                <b>XRack</b>
                <span><T en="Sovereign Cognitive Runtime" tr="Bağımsız Bilişsel Runtime" /></span>
              </span>
            </a>
            <p><span data-lang-content="en">{SITE.description}</span><span data-lang-content="tr">{SITE_TR.description}</span></p>
          </div>

          <div class="foot-cols">
            <div>
              <h2 class="eyebrow">Blog</h2>
              <ul>
                <li><a href={href()}><T en="All" tr="Tümü" /></a></li>
                {
                  NAV.map((item) => (
                    <li>
                      {hasPosts(item.tag) ? (
                        <a href={href(`tags/${item.tag}`)}><T en={item.label} tr={item.label_tr} /></a>
                      ) : (
                        <span class="is-empty"><T en={item.label} tr={item.label_tr} /></span>
                      )}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h2 class="eyebrow">XRack</h2>
              <ul>
                <li><a href={SITE.homepage} target="_blank" rel="noopener"><T en="Product" tr="Ürün" /></a></li>
                <li><a href={`${SITE.homepage}/demos.html`} target="_blank" rel="noopener"><T en="Demos" tr="Demolar" /></a></li>
                <li><a href={href("about")}><T en="About" tr="Hakkında" /></a></li>
              </ul>
            </div>
            <div>
              <h2 class="eyebrow"><T en="Contact" tr="İletişim" /></h2>
              <ul>
                <li><a href="mailto:dogandursun@xrack.io">dogandursun@xrack.io</a></li>
                <li><a href={SITE.cta} target="_blank" rel="noopener"><T en="Book a Demo" tr="Demo Planla" /></a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="site-foot-bottom">
          <div>&copy; {year} XRack Technologies. <T en="All rights reserved." tr="Tüm hakları saklıdır." /></div>
          <div><T en="Built with cognition." tr="Bilişle inşa edildi." /></div>
        </div>
      </div>
    </footer>

    <script>
      // Header elevation on scroll
      const bar = document.getElementById("topbar");
      const onScroll = () => bar?.classList.toggle("is-scrolled", window.scrollY > 8);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      // Mobile menu
      const menuBtn = document.getElementById("menuBtn");
      const menu = document.getElementById("mobileMenu");
      const setMenu = (open: boolean) => {
        menu?.classList.toggle("open", open);
        menuBtn?.setAttribute("aria-expanded", open ? "true" : "false");
        menuBtn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        bar?.classList.toggle("menu-open", open);
      };
      menuBtn?.addEventListener("click", () =>
        setMenu(menuBtn.getAttribute("aria-expanded") !== "true"),
      );
      menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") setMenu(false); });
      window.addEventListener("resize", () => { if (window.innerWidth > 900) setMenu(false); });

      // Language switch (EN/TR) — remembers the choice in localStorage
      const LANG_KEY = "xrack-blog-lang";
      const langButtons = document.querySelectorAll(".lang-opt");
      const applyLang = (lang: string) => {
        const l = lang === "tr" ? "tr" : "en";
        document.documentElement.dataset.lang = l;
        document.documentElement.lang = l;
        try { localStorage.setItem(LANG_KEY, l); } catch (e) {}
        langButtons.forEach((b) => {
          const on = b.getAttribute("data-lang-opt") === l;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        document.querySelectorAll("[data-ph-en]").forEach((el) => {
          const ph = l === "tr" ? el.getAttribute("data-ph-tr") : el.getAttribute("data-ph-en");
          if (ph) el.setAttribute("placeholder", ph);
        });
      };
      langButtons.forEach((b) =>
        b.addEventListener("click", () => applyLang(b.getAttribute("data-lang-opt") ?? "en")),
      );
      applyLang(document.documentElement.dataset.lang || "en");

      // Scroll-reveal
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
      );
      document.querySelectorAll(".reveal-on-view").forEach((el) => io.observe(el));

      // Reading-progress bar (article pages only)
      const progress = document.getElementById("readProgress");
      if (progress) {
        const onProgress = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
          progress.style.width = pct + "%";
        };
        onProgress();
        window.addEventListener("scroll", onProgress, { passive: true });
        window.addEventListener("resize", onProgress, { passive: true });
      }
    </script>
  </body>
</html>
