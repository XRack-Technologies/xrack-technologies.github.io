---
import "../styles/global.css";
import { getCollection } from "astro:content";
import { SITE, SITE_TR, NAV, SOCIAL, href, GOOGLE_VERIFICATION, BING_VERIFICATION } from "../lib/site";
import { Font } from "astro:assets";
import T from "../components/T.astro";
import Analytics from "../components/Analytics.astro";

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  publishedTime?: string;
  articleTags?: string[];
  showProgress?: boolean;
  jsonLd?: unknown;
  image?: string;
  forceLang?: "en" | "tr";
  alternates?: { en: string; tr: string };
  feed?: { href: string; title: string };
}

const allPosts = await getCollection("blog", ({ data }) => !data.draft);
const activeTags = new Set(allPosts.flatMap((p) => p.data.tags));
const hasPosts = (tag: string) => activeTags.has(tag);
const {
  title,
  description = SITE.description,
  ogType = "website",
  publishedTime,
  articleTags = [],
  showProgress = false,
  jsonLd,
  image,
  forceLang,
  alternates,
  feed,
} = Astro.props;
const isTr = forceLang === "tr";
const htmlLang = isTr ? "tr" : "en";
const forceLangVal = forceLang ?? "";
const pageTitle = title ? `${title} · ${SITE.title}` : `${SITE.title} · ${SITE.tagline}`;
const path = Astro.url.pathname.replace(/\/$/, "");
const logo = href("logo.png");
const isActive = (tag: string) => path === href(`tags/${tag}`).replace(/\/$/, "");
const homeActive = path === href().replace(/\/$/, "");
const aboutActive = path === href("about").replace(/\/$/, "");
const canonical = Astro.site ? new URL(Astro.url.pathname, Astro.site).href : Astro.url.pathname;
const defaultOg = href("og/default.png");
const ogImage = image ?? (Astro.site ? new URL(defaultOg, Astro.site).href : defaultOg);
const year = new Date().getFullYear();
const siteHref = Astro.site ? Astro.site.href : "https://blog.xrack.io/";
const logoAbs = Astro.site ? new URL(logo, Astro.site).href : logo;
const orgLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: "XRack Technologies",
  url: SITE.homepage,
  logo: logoAbs,
  sameAs: ["https://github.com/XRack-Technologies", SOCIAL.linkedin],
};
const siteLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE.title,
  url: siteHref,
  inLanguage: ["en", "tr"],
  publisher: { "@type": "Organization", name: "XRack Technologies", url: SITE.homepage },
  potentialAction: {
    "@type": "SearchAction",
    target: { "@type": "EntryPoint", urlTemplate: `${siteHref}?q={search_term_string}` },
    "query-input": "required name=search_term_string",
  },
};
const graph = [orgLd, siteLd, ...(jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [])];
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0c0b0a" />
    <script is:inline define:vars={{ forceLangVal }}>
      try {
        var _q = new URLSearchParams(location.search).get("lang");
        var _l =
          _q === "en" || _q === "tr"
            ? _q
            : forceLangVal === "en" || forceLangVal === "tr"
              ? forceLangVal
              : localStorage.getItem("xrack-blog-lang") || "en";
        document.documentElement.dataset.lang = _l;
        document.documentElement.lang = _l;
        if (_q) localStorage.setItem("xrack-blog-lang", _l);
      } catch (e) {
        document.documentElement.dataset.lang = "en";
      }
    </script>
    <script is:inline>
      try {
        var _t = localStorage.getItem("xrack-theme");
        if (_t !== "light" && _t !== "dark") {
          _t =
            window.matchMedia && window.matchMedia("(prefers-color-scheme: light)").matches
              ? "light"
              : "dark";
        }
        document.documentElement.setAttribute("data-theme", _t);
        var _m = document.querySelector('meta[name="theme-color"]');
        if (_m) _m.setAttribute("content", _t === "light" ? "#f4efe6" : "#0c0b0a");
      } catch (e) {
        document.documentElement.setAttribute("data-theme", "dark");
      }
    </script>
    <link rel="icon" href={href("favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" sizes="32x32" href={href("favicon-32.png")} />
    <link rel="icon" type="image/png" sizes="16x16" href={href("favicon-16.png")} />
    <link rel="apple-touch-icon" sizes="180x180" href={href("apple-touch-icon.png")} />
    <link rel="manifest" href={href("site.webmanifest")} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    {GOOGLE_VERIFICATION && <meta name="google-site-verification" content={GOOGLE_VERIFICATION} />}
    {BING_VERIFICATION && <meta name="msvalidate.01" content={BING_VERIFICATION} />}
    <link rel="canonical" href={canonical} />
    {
      alternates && (
        <>
          <link rel="alternate" hreflang="en" href={alternates.en} />
          <link rel="alternate" hreflang="tr" href={alternates.tr} />
          <link rel="alternate" hreflang="x-default" href={alternates.en} />
        </>
      )
    }
    <link rel="alternate" type="application/rss+xml" title={SITE.title} href={href("rss.xml")} />
    {feed && <link rel="alternate" type="application/rss+xml" title={feed.title} href={feed.href} />}
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={SITE.title} />
    <meta property="og:locale" content={isTr ? "tr_TR" : "en_US"} />
    <meta property="og:locale:alternate" content={isTr ? "en_US" : "tr_TR"} />
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {ogType === "article" && <meta property="article:author" content={SITE.author} />}
    {articleTags.map((t) => <meta property="article:tag" content={t} />)}
    <meta name="twitter:card" content="summary_large_image" />
    {SITE.twitter && <meta name="twitter:site" content={SITE.twitter} />}
    {SITE.twitter && <meta name="twitter:creator" content={SITE.twitter} />}
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="generator" content={Astro.generator} />
    {graph.map((item) => <script type="application/ld+json" set:html={JSON.stringify(item)} />)}
    <Font cssVariable="--font-geist" preload />
    <Font cssVariable="--font-bricolage" preload />
    <Font cssVariable="--font-instrument" />
    <Font cssVariable="--font-jetbrains" />
  </head>
  <body>
    <a class="skip-link" href="#main"><T en="Skip to content" tr="İçeriğe geç" /></a>
    {showProgress && <div class="read-progress" id="readProgress" aria-hidden="true"></div>}
    <header id="topbar" class="topbar-shell">
      <div class="topbar-inner">
        <a class="brand" href={href()}>
          <span class="brand-mark"><img src={logo} alt="" /></span>
          <span class="brand-name">
            <b>XRack</b>
            <span><T en="Blog · Sovereign Cognitive Runtime" tr="Blog · Bağımsız Bilişsel Çalışma Zamanı" /></span>
          </span>
        </a>

        <nav class="nav-rail nav-desktop" aria-label="Primary">
          <a class="nav-link" href={href()} aria-current={homeActive ? "page" : undefined}><T en="All" tr="Tümü" /></a>
          {
            NAV.map((item) =>
              hasPosts(item.tag) ? (
                <a class="nav-link" href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}><T en={item.label} tr={item.label_tr} /></a>
              ) : (
                <span class="nav-link nav-link--empty" aria-disabled="true"><T en={item.label} tr={item.label_tr} /></span>
              ),
            )
          }
          <a class="nav-link" href={href("about")} aria-current={aboutActive ? "page" : undefined}><T en="About" tr="Hakkında" /></a>
        </nav>

        <div class="topbar-actions nav-desktop">
          <button class="theme-toggle" type="button" data-toggle-theme aria-label="Toggle color theme">
            <svg class="i-sun" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
            <svg class="i-moon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
          <div class="lang-toggle" role="group" aria-label="Language">
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="en">EN</button>
            <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="tr">TR</button>
          </div>
          <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">
            xrack.io
            <svg viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7"/><path d="M8 7h9v9"/></svg>
          </a>
          <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener">
            <T en="Book a Demo" tr="Demo Planla" />
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
          </a>
        </div>

        <button class="menu-btn" id="menuBtn" type="button" aria-label="Open menu" aria-controls="mobileMenu" aria-expanded="false">
          <svg class="i-open" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 6h16"/><path d="M4 12h16"/><path d="M4 18h16"/></svg>
          <svg class="i-close" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 6l12 12"/><path d="M18 6 6 18"/></svg>
        </button>
      </div>

      <div class="mobile-menu" id="mobileMenu">
        <div class="mobile-menu__inner">
          <nav class="mobile-nav" aria-label="Mobile">
            <a href={href()} aria-current={homeActive ? "page" : undefined}><T en="All" tr="Tümü" /></a>
            {
              NAV.map((item) =>
                hasPosts(item.tag) ? (
                  <a href={href(`tags/${item.tag}`)} aria-current={isActive(item.tag) ? "page" : undefined}><T en={item.label} tr={item.label_tr} /></a>
                ) : (
                  <span class="is-empty" aria-disabled="true"><T en={item.label} tr={item.label_tr} /></span>
                ),
              )
            }
            <a href={href("about")} aria-current={aboutActive ? "page" : undefined}><T en="About" tr="Hakkında" /></a>
          </nav>
          <div class="mobile-prefs">
            <div class="lang-toggle lang-toggle--mobile" role="group" aria-label="Language">
              <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="en">EN</button>
              <button class="lang-opt" type="button" aria-pressed="false" data-lang-opt="tr">TR</button>
            </div>
            <button class="theme-toggle" type="button" data-toggle-theme aria-label="Toggle color theme">
              <svg class="i-sun" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/></svg>
              <svg class="i-moon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
          </div>
          <div class="mobile-actions">
            <a class="btn-ghost" href={SITE.homepage} target="_blank" rel="noopener">xrack.io</a>
            <a class="btn-primary" href={SITE.cta} target="_blank" rel="noopener"><T en="Book a Demo" tr="Demo Planla" /></a>
          </div>
        </div>
      </div>
    </header>

    <main id="main">
      <slot />
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div class="site-foot-top">
          <div class="foot-about">
            <a class="brand" href={href()}>
              <span class="brand-mark"><img src={logo} alt="" /></span>
              <span class="brand-name">
                <b>XRack</b>
                <span><T en="Sovereign Cognitive Runtime" tr="Bağımsız Bilişsel Çalışma Zamanı" /></span>
              </span>
            </a>
            <p><span data-lang-content="en">{SITE.description}</span><span data-lang-content="tr">{SITE_TR.description}</span></p>
            <div class="foot-social">
              <a class="social-link" href={SOCIAL.linkedin} target="_blank" rel="noopener" aria-label="XRack on LinkedIn">
                <svg viewBox="0 0 24 24" width="15" height="15" fill="currentColor" aria-hidden="true"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                <T en="Follow on LinkedIn" tr="LinkedIn'de takip et" />
              </a>
            </div>
          </div>

          <div class="foot-cols">
            <div>
              <h2 class="eyebrow">Blog</h2>
              <ul>
                <li><a href={href()}><T en="All" tr="Tümü" /></a></li>
                <li><a href={href("archive")}><T en="Archive" tr="Arşiv" /></a></li>
                {
                  NAV.map((item) => (
                    <li>
                      {hasPosts(item.tag) ? (
                        <a href={href(`tags/${item.tag}`)}><T en={item.label} tr={item.label_tr} /></a>
                      ) : (
                        <span class="is-empty"><T en={item.label} tr={item.label_tr} /></span>
                      )}
                    </li>
                  ))
                }
              </ul>
            </div>
            <div>
              <h2 class="eyebrow">XRack</h2>
              <ul>
                <li><a href={SITE.homepage} target="_blank" rel="noopener"><T en="Product" tr="Ürün" /></a></li>
                <li><a href={`${SITE.homepage}/demos.html`} target="_blank" rel="noopener"><T en="Demos" tr="Demolar" /></a></li>
                <li><a href={href("about")}><T en="About" tr="Hakkında" /></a></li>
                <li><a href={href("press")}><T en="Press" tr="Basın" /></a></li>
              </ul>
            </div>
            <div>
              <h2 class="eyebrow"><T en="Contact" tr="İletişim" /></h2>
              <ul>
                <li><a href="mailto:dogandursun@xrack.io">dogandursun@xrack.io</a></li>
                <li><a href={SITE.cta} target="_blank" rel="noopener"><T en="Book a Demo" tr="Demo Planla" /></a></li>
                <li><a href={href("privacy")}><T en="Privacy" tr="Gizlilik" /></a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="site-foot-bottom">
          <div>&copy; {year} XRack Technologies. <T en="All rights reserved." tr="Tüm hakları saklıdır." /></div>
          <div class="site-foot-bottom__links">
            <a href={href("privacy")}><T en="Privacy" tr="Gizlilik" /></a>
            <span aria-hidden="true">·</span>
            <a href={href("press")}><T en="Press" tr="Basın" /></a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const bar = document.getElementById("topbar");
      const onScroll = () => bar?.classList.toggle("is-scrolled", window.scrollY > 8);
      onScroll();
      window.addEventListener("scroll", onScroll, { passive: true });

      const menuBtn = document.getElementById("menuBtn");
      const menu = document.getElementById("mobileMenu");
      const setMenu = (open: boolean) => {
        menu?.classList.toggle("open", open);
        menuBtn?.setAttribute("aria-expanded", open ? "true" : "false");
        menuBtn?.setAttribute("aria-label", open ? "Close menu" : "Open menu");
        bar?.classList.toggle("menu-open", open);
      };
      menuBtn?.addEventListener("click", () =>
        setMenu(menuBtn.getAttribute("aria-expanded") !== "true"),
      );
      menu?.querySelectorAll("a").forEach((a) => a.addEventListener("click", () => setMenu(false)));
      document.addEventListener("keydown", (e) => { if (e.key === "Escape") setMenu(false); });
      window.addEventListener("resize", () => { if (window.innerWidth > 900) setMenu(false); });
      const THEME_KEY = "xrack-theme";
      const themeMeta = document.querySelector('meta[name="theme-color"]');
      const themeToggles = document.querySelectorAll("[data-toggle-theme]");
      const currentTheme = () =>
        document.documentElement.getAttribute("data-theme") === "light" ? "light" : "dark";
      const applyTheme = (t: string) => {
        document.documentElement.setAttribute("data-theme", t);
        themeMeta?.setAttribute("content", t === "light" ? "#f4efe6" : "#0c0b0a");
        themeToggles.forEach((b) =>
          b.setAttribute("aria-label", t === "light" ? "Switch to dark theme" : "Switch to light theme"),
        );
        const gi = document.querySelector<HTMLIFrameElement>("iframe.giscus-frame");
        gi?.contentWindow?.postMessage(
          { giscus: { setConfig: { theme: t === "light" ? "light" : "transparent_dark" } } },
          "https://giscus.app",
        );
      };
      themeToggles.forEach((btn) =>
        btn.addEventListener("click", () => {
          const next = currentTheme() === "light" ? "dark" : "light";
          applyTheme(next);
          try { localStorage.setItem(THEME_KEY, next); } catch (e) {}
        }),
      );
      applyTheme(currentTheme());
      if (window.matchMedia) {
        const mq = window.matchMedia("(prefers-color-scheme: light)");
        const onThemeChange = (e: MediaQueryListEvent) => {
          let saved = null;
          try { saved = localStorage.getItem(THEME_KEY); } catch (err) {}
          if (saved === "light" || saved === "dark") return;
          applyTheme(e.matches ? "light" : "dark");
        };
        if (mq.addEventListener) mq.addEventListener("change", onThemeChange);
      }

      const LANG_KEY = "xrack-blog-lang";
      const langButtons = document.querySelectorAll(".lang-opt");
      const applyLang = (lang: string) => {
        const l = lang === "tr" ? "tr" : "en";
        document.documentElement.dataset.lang = l;
        document.documentElement.lang = l;
        langButtons.forEach((b) => {
          const on = b.getAttribute("data-lang-opt") === l;
          b.classList.toggle("is-active", on);
          b.setAttribute("aria-pressed", on ? "true" : "false");
        });
        document.querySelectorAll("[data-ph-en]").forEach((el) => {
          const ph = l === "tr" ? el.getAttribute("data-ph-tr") : el.getAttribute("data-ph-en");
          if (ph) el.setAttribute("placeholder", ph);
        });
        document.querySelectorAll<HTMLAnchorElement>("a[data-href-tr]").forEach((a) => {
          if (!a.dataset.hrefEn) a.dataset.hrefEn = a.getAttribute("href") || "";
          a.setAttribute("href", l === "tr" ? a.dataset.hrefTr! : a.dataset.hrefEn);
        });
      };
      const norm = (p: string) => p.replace(/\/+$/, "");
      const altUrlFor = (lang: string): string | null => {
        const link = document.querySelector<HTMLLinkElement>(
          `link[rel="alternate"][hreflang="${lang}"]`,
        );
        const hrefAttr = link?.getAttribute("href");
        if (!hrefAttr) return null;
        try {
          const dest = new URL(hrefAttr, location.href);
          if (norm(dest.pathname) === norm(location.pathname)) return null;
          return dest.pathname + dest.search + dest.hash;
        } catch (e) {
          return null;
        }
      };
      langButtons.forEach((b) =>
        b.addEventListener("click", () => {
          const target = b.getAttribute("data-lang-opt") ?? "en";
          const dest = altUrlFor(target);
          try { localStorage.setItem(LANG_KEY, target); } catch (e) {}
          if (dest) {
            location.href = dest;
          } else {
            applyLang(target);
          }
        }),
      );
      applyLang(document.documentElement.dataset.lang || "en");

      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              io.unobserve(e.target);
            }
          }
        },
        { rootMargin: "0px 0px -8% 0px", threshold: 0.05 },
      );
      document.querySelectorAll(".reveal-on-view").forEach((el) => io.observe(el));

      const progress = document.getElementById("readProgress");
      if (progress) {
        const onProgress = () => {
          const h = document.documentElement;
          const max = h.scrollHeight - h.clientHeight;
          const pct = max > 0 ? (h.scrollTop / max) * 100 : 0;
          progress.style.width = pct + "%";
        };
        onProgress();
        window.addEventListener("scroll", onProgress, { passive: true });
        window.addEventListener("resize", onProgress, { passive: true });
      }
    </script>
    <Analytics />
  </body>
</html>
