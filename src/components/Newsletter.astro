---
import T from "./T.astro";
import { NEWSLETTER } from "../lib/site";

interface Props {
  variant?: "card" | "compact";
}
const { variant = "card" } = Astro.props;
const subscribeUrl = `${NEWSLETTER.url}/subscribe`;
---

<div class={`nl nl--${variant}`} data-newsletter-box>
  <div class="nl__intro">
    <span class="nl__eyebrow"><T en="The XRack Journal" tr="XRack Günlüğü" /></span>
    {variant === "card" && (
      <p class="nl__title"><T en="New posts, straight to your inbox" tr="Yeni yazılar doğrudan gelen kutuna" /></p>
    )}
    <p class="nl__sub">
      {
        variant === "card" ? (
          <T
            en="Engineering, research, and field notes on building the observable agentic harness. No spam — unsubscribe anytime."
            tr="Gözlemlenebilir agentic harness'ı inşa üzerine mühendislik, araştırma ve saha notları. Spam yok — istediğin an çık."
          />
        ) : (
          <T en="Get new posts by email. No spam." tr="Yeni yazıları e-postayla al. Spam yok." />
        )
      }
    </p>
  </div>

  <form
    class="nl__form"
    data-newsletter
    action={NEWSLETTER.action}
    method="post"
    target="_blank"
    novalidate
  >
    <input type="hidden" name="source" value="embed" />
    <div class="nl__row">
      <input
        class="nl__input"
        type="email"
        name="email"
        required
        autocomplete="email"
        aria-label="Email address"
        data-ph-en="you@company.com"
        data-ph-tr="sen@sirket.com"
        placeholder="you@company.com"
      />
      <button class="btn-primary nl__btn" type="submit">
        <span class="nl__btn-label"><T en="Subscribe" tr="Abone ol" /></span>
        <svg class="nl__btn-arrow" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="M13 5l7 7-7 7"/></svg>
        <span class="nl__spinner" aria-hidden="true"></span>
      </button>
    </div>
    <p class="nl__error" role="alert"><T en="Please enter a valid email address." tr="Lütfen geçerli bir e-posta adresi girin." /></p>
    <p class="nl__failed" role="alert"><T en="Couldn't subscribe you just now — please use the Substack link below." tr="Şu an abone edemedik — aşağıdaki Substack bağlantısını kullanın." /></p>
    <p class="nl__note">
      <T en="Double opt-in — we'll email a confirmation link." tr="Çift onay — bir doğrulama bağlantısı göndeririz." />
      {" "}
      <a href={subscribeUrl} target="_blank" rel="noopener"><T en="Or subscribe on Substack" tr="Veya Substack'te abone ol" /> ↗</a>
    </p>
  </form>

  <div class="nl__success" role="status" aria-live="polite">
    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
    <span><T en="Almost there — check your inbox to confirm your subscription." tr="Az kaldı — aboneliğini onaylamak için gelen kutunu kontrol et." /></span>
  </div>
</div>

<style>
  .nl {
    position: relative; isolation: isolate; border-radius: var(--radius);
    border: 1px solid hsl(var(--border));
    background-image: linear-gradient(180deg, hsl(var(--card-elevated)), hsl(var(--card)));
    box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.04);
  }
  .nl--card { padding: 2.25rem 2rem; overflow: hidden; }
  .nl--card::after {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; border-radius: inherit;
    background: radial-gradient(440px 180px at 50% 0%, hsl(var(--primary) / 0.12), transparent 70%);
  }
  .nl--compact { padding: 1.4rem 1.5rem; display: flex; flex-wrap: wrap; align-items: center; gap: 1rem 1.5rem; }

  .nl__eyebrow { font-family: var(--font-mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: hsl(var(--primary)); }
  .nl__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.4rem, 3vw, 1.9rem); letter-spacing: -0.02em; line-height: 1.1; margin: 0.6rem 0 0; color: hsl(var(--ink)); text-wrap: balance; }
  .nl__sub { margin: 0.6rem 0 0; color: hsl(var(--muted-foreground)); font-size: 14.5px; line-height: 1.6; max-width: 42rem; }
  .nl--compact .nl__intro { flex: 1 1 240px; }
  .nl--compact .nl__sub { margin-top: 0.25rem; font-size: 13px; }

  .nl__form { margin-top: 1.35rem; }
  .nl--compact .nl__form { margin-top: 0; flex: 1 1 320px; }
  .nl__row { display: flex; flex-wrap: wrap; gap: 0.6rem; }
  .nl__input {
    flex: 1 1 220px; min-width: 0; font-family: var(--font-sans); font-size: 15px;
    color: hsl(var(--foreground)); background: hsl(var(--background) / 0.5);
    border: 1px solid hsl(var(--border-strong)); border-radius: 9999px; padding: 0.7rem 1.1rem;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  .nl__input::placeholder { color: hsl(var(--muted-foreground) / 0.8); }
  .nl__input:focus { outline: none; border-color: hsl(var(--primary) / 0.6); box-shadow: 0 0 0 3px hsl(var(--primary) / 0.15); }
  .nl__btn { flex-shrink: 0; padding: 0.7rem 1.4rem; font-size: 14px; position: relative; }
  .nl__btn-arrow { transition: transform 0.18s ease; }
  .nl__btn:hover .nl__btn-arrow { transform: translateX(2px); }

  .nl__spinner {
    display: none; width: 15px; height: 15px; border-radius: 50%;
    border: 2px solid hsl(var(--primary-foreground) / 0.35); border-top-color: hsl(var(--primary-foreground));
    animation: nlspin 0.7s linear infinite;
  }
  @keyframes nlspin { to { transform: rotate(360deg); } }

  .nl__error, .nl__failed { display: none; margin: 0.6rem 0 0; font-size: 13px; color: hsl(var(--rose)); }
  .nl__note { margin: 0.85rem 0 0; font-size: 12.5px; line-height: 1.5; color: hsl(var(--muted-foreground)); }
  .nl__note a { color: hsl(var(--primary-soft)); white-space: nowrap; }
  .nl__note a:hover { color: hsl(var(--primary)); }
  .nl--compact .nl__note { margin-top: 0.55rem; }

  .nl__success {
    display: none; align-items: center; gap: 0.6rem; margin-top: 0.5rem;
    color: hsl(var(--success)); font-size: 14.5px; line-height: 1.5;
  }
  .nl--card .nl__success { padding: 0.5rem 0; }
  .nl__success svg { flex-shrink: 0; }

  /* State machine (driven by data-state on the box) */
  [data-newsletter-box][data-state="error"] .nl__error { display: block; }
  [data-newsletter-box][data-state="failed"] .nl__failed { display: block; }
  [data-newsletter-box][data-state="loading"] .nl__btn-label,
  [data-newsletter-box][data-state="loading"] .nl__btn-arrow { visibility: hidden; }
  [data-newsletter-box][data-state="loading"] .nl__spinner { display: inline-block; }
  [data-newsletter-box][data-state="loading"] .nl__btn { pointer-events: none; }
  [data-newsletter-box][data-state="done"] .nl__form { display: none; }
  [data-newsletter-box][data-state="done"] .nl__success { display: flex; }
</style>

<script>
  document.querySelectorAll<HTMLFormElement>("form[data-newsletter]").forEach((form) => {
    if (form.dataset.bound) return;
    form.dataset.bound = "1";
    const box = form.closest<HTMLElement>("[data-newsletter-box]");
    const email = form.querySelector<HTMLInputElement>('input[name="email"]');
    if (!box || !email) return;
    const valid = (v: string) => /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v);

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const v = (email.value || "").trim();
      if (!valid(v)) {
        box.dataset.state = "error";
        email.focus();
        return;
      }
      box.dataset.state = "loading";
      try {
        const body = new URLSearchParams({ email: v, source: "embed" });
        await fetch(form.action, {
          method: "POST",
          mode: "no-cors",
          headers: { "Content-Type": "application/x-www-form-urlencoded" },
          body,
        });
        box.dataset.state = "done";
      } catch (err) {
        box.dataset.state = "failed";
      }
    });

    email.addEventListener("input", () => {
      const s = box.dataset.state;
      if (s === "error" || s === "failed") box.dataset.state = "";
    });
  });
</script>
