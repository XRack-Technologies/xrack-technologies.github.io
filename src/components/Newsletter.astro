---
import T from "./T.astro";
import { NEWSLETTER } from "../lib/site";

const formId = NEWSLETTER.emailOctopusFormId;
const scriptSrc = `https://eomail5.com/form/${formId}.js`;
---

<div class="nl" data-newsletter-box>
  <div class="nl__intro">
    <span class="nl__eyebrow"><T en="The XRack Journal" tr="XRack Günlüğü" /></span>
    <p class="nl__title"><T en="New posts, straight to your inbox." tr="Gelişmeler doğrudan e-postana gelsin." /></p>
    <p class="nl__sub">
      <T
        en="Engineering, research, and field notes on building the observable agentic harness. No spam, you can unsubscribe anytime."
        tr="Gözlemlenebilir agentic harness'ı inşa üzerine mühendislik, araştırma ve saha notları. Spam yok, istediğin an abonelikten çıkabilirsin."
      />
    </p>
  </div>

  <div class="nl__embed">
    <script is:inline async src={scriptSrc} data-form={formId}></script>
  </div>
</div>

<style>
  .nl {
    position: relative; isolation: isolate; border-radius: var(--radius);
    border: 1px solid hsl(var(--border));
    background-image: linear-gradient(180deg, hsl(var(--card-elevated)), hsl(var(--card)));
    box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.04);
    padding: 2.25rem 2rem; overflow: hidden;
  }
  .nl::after {
    content: ""; position: absolute; inset: 0; z-index: -1; pointer-events: none; border-radius: inherit;
    background: radial-gradient(440px 180px at 50% 0%, hsl(var(--primary) / 0.12), transparent 70%);
  }
  .nl__eyebrow { font-family: var(--font-mono); font-size: 10.5px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: hsl(var(--primary)); }
  .nl__title { font-family: var(--font-display); font-weight: 600; font-size: clamp(1.4rem, 3vw, 1.9rem); letter-spacing: -0.02em; line-height: 1.1; margin: 0.6rem 0 0; color: hsl(var(--ink)); text-wrap: balance; }
  .nl__sub { margin: 0.6rem 0 0 0; color: hsl(var(--muted-foreground)); font-size: 14.5px; line-height: 1.6; max-width: 42rem; }
  .nl__embed { margin-top: 1.4rem; }
  .nl__embed :global(.inline-container) { max-width: 100% !important; }
  .nl__embed :global(.emailoctopus-form) { font-family: var(--font-sans) !important; }
  /* Left-align the form (widget centers it) and align input + button on one row. */
  .nl__embed :global(.form-container),
  .nl__embed :global(.emailoctopus-form-wrapper),
  .nl__embed :global(.emailoctopus-form),
  .nl__embed :global(.main-form) {
    margin-left: 0 !important; margin-right: 0 !important;
    max-width: 100% !important; text-align: left !important;
  }
  .nl__embed :global(.main-form) {
    display: flex !important;
    justify-content: flex-start !important;
    align-items: flex-start !important;
    gap: 0.6rem !important;
    max-width: 620px !important;
  }
  .nl__embed :global(.main-form > div) { flex: 1 1 240px !important; margin: 0 !important; }
  .nl__embed :global(.emailoctopus-form-row) { margin: 0 !important; }
  .nl__embed :global(.form-control) {
    background: hsl(var(--background) / 0.5) !important;
    border: 1px solid hsl(var(--border-strong)) !important;
    color: hsl(var(--foreground)) !important;
    border-radius: 9999px !important;
    font-family: var(--font-sans) !important;
    font-size: 15px !important;
    height: 46px !important;
    width: 100% !important;
    padding: 0 1.1rem !important;
    box-shadow: none !important;
  }
  .nl__embed :global(.form-control::placeholder) { color: hsl(var(--muted-foreground) / 0.8) !important; }
  .nl__embed :global(.form-control:focus) { border-color: hsl(var(--primary) / 0.6) !important; box-shadow: 0 0 0 3px hsl(var(--primary) / 0.15) !important; outline: none !important; }
  .nl__embed :global(input.btn), .nl__embed :global(.btn-primary) {
    background: linear-gradient(180deg, hsl(var(--primary-soft)), hsl(var(--primary))) !important;
    color: hsl(var(--primary-foreground)) !important;
    border: 0 !important; border-radius: 9999px !important;
    font-family: var(--font-sans) !important; font-weight: 600 !important; font-size: 14px !important;
    height: 46px !important; width: auto !important; margin: 0 !important;
    padding: 0 1.5rem !important; cursor: pointer !important;
    box-shadow: inset 0 1px 0 hsl(0 0% 100% / 0.18), 0 6px 18px -8px hsl(var(--primary) / 0.55) !important;
    transition: transform 0.18s ease, box-shadow 0.2s ease !important;
  }
  .nl__embed :global(input.btn:hover), .nl__embed :global(.btn-primary:hover) { transform: translateY(-1px) !important; }
  .nl__embed :global(.emailoctopus-form-row-consent),
  .nl__embed :global(.emailoctopus-form-row-consent *) {
    color: hsl(var(--muted-foreground)) !important;
    font-family: var(--font-sans) !important;
    font-size: 12.5px !important; line-height: 1.5 !important;
  }
  .nl__embed :global(.emailoctopus-form-row-consent) { margin-top: 1rem !important; display: flex !important; align-items: flex-start !important; gap: 0.5rem !important; }
  .nl__embed :global(.emailoctopus-form-row-consent input[type="checkbox"]) { margin: 0.2rem 0 0 0 !important; flex-shrink: 0 !important; }
  .nl__embed :global(.emailoctopus-form-row-consent label) { margin: 0 !important; }
  .nl__embed :global(.emailoctopus-success-message) { color: hsl(var(--success)) !important; font-family: var(--font-sans) !important; }
  .nl__embed :global(.emailoctopus-error-message) { color: hsl(var(--rose)) !important; font-family: var(--font-sans) !important; }
  .nl__embed :global(.mastfoot) { opacity: 0.55; margin-top: 0.4rem; }
  .nl__embed :global(a) { color: hsl(var(--primary-soft)) !important; }
  /* Higher specificity to beat EmailOctopus' Bootstrap `.w-100 { width:100% !important }`
     so the button hugs its label and the row stays compact + left-aligned. */
  .nl__embed :global(.emailoctopus-form .main-form) { max-width: 540px !important; }
  .nl__embed :global(.emailoctopus-form .main-form > div) { flex: 1 1 auto !important; }
  .nl__embed :global(.emailoctopus-form .main-form input.btn) { flex: 0 0 auto !important; width: auto !important; min-width: 140px !important; }
</style>
