---

<div
  class={isRail ? "share-rail" : "share-bar"}
  aria-label="Share this post"
  data-share
  data-share-url={url}
  data-share-url-tr={urlTr}
  data-title-en={title}
  data-title-tr={titleTr}
>
  {!isRail && <span class="share-label"><T en="Share" tr="Paylaş" /></span>}
  <div class="share-btns">
    {
      links.map((l) => (
        <a
          class="share-btn"
          href={render(l.tpl)}
          data-tpl={l.tpl}
          target="_blank"
          rel="noopener"
          aria-label={`Share on ${l.name}`}
          title={l.name}
        >
          <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true" set:html={l.svg} />
        </a>
      ))
    }
    <button class="share-btn share-copy" type="button" data-url={url} aria-label="Copy link" title="Copy link">
      <svg class="i-link" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
      <svg class="i-check" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 6 9 17l-5-5"/></svg>
    </button>
  </div>
</div>

<script>
  document.querySelectorAll<HTMLButtonElement>(".share-copy").forEach((btn) => {
    if (btn.dataset.bound) return;
    btn.dataset.bound = "1";
    btn.addEventListener("click", async () => {
      const shareUrl = btn.getAttribute("data-url") || location.href;
      try {
        await navigator.clipboard.writeText(shareUrl);
      } catch (e) {
        const ta = document.createElement("textarea");
        ta.value = shareUrl;
        ta.style.position = "fixed";
        ta.style.opacity = "0";
        document.body.appendChild(ta);
        ta.select();
        try { document.execCommand("copy"); } catch (e2) {}
        document.body.removeChild(ta);
      }
      btn.classList.add("is-copied");
      window.setTimeout(() => btn.classList.remove("is-copied"), 1500);
    });
  });

  const enc = encodeURIComponent;
  const buildShareLinks = (lang: string) => {
    document.querySelectorAll<HTMLElement>("[data-share]").forEach((box) => {
      const en = box.dataset.shareUrl || location.href.split("?")[0];
      const shareUrl = lang === "tr" ? box.dataset.shareUrlTr || en : en;
      const title = (lang === "tr" ? box.dataset.titleTr : box.dataset.titleEn) || "";
      box.querySelectorAll<HTMLAnchorElement>("a[data-tpl]").forEach((a) => {
        const tpl = a.dataset.tpl || "";
        a.href = tpl.replaceAll("{u}", enc(shareUrl)).replaceAll("{t}", enc(title));
      });
      box.querySelectorAll<HTMLElement>(".share-copy").forEach((b) => {
        b.setAttribute("data-url", shareUrl);
      });
    });
  };
  const currentLang = () => (document.documentElement.dataset.lang === "tr" ? "tr" : "en");
  buildShareLinks(currentLang());
  new MutationObserver(() => buildShareLinks(currentLang())).observe(
    document.documentElement,
    { attributes: true, attributeFilter: ["data-lang"] },
  );

  const rail = document.querySelector<HTMLElement>(".share-rail");
  const bar = document.querySelector<HTMLElement>(".share-bar");
  if (rail && bar && "IntersectionObserver" in window && !rail.dataset.tuckBound) {
    rail.dataset.tuckBound = "1";
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          rail.classList.toggle("is-tucked", entry.isIntersecting);
        }
      },
      { rootMargin: "0px 0px -15% 0px" },
    );
    io.observe(bar);
  }
</script>
