---
import T from "./T.astro";

interface Props {
  url: string;
  urlTr?: string;
  title: string;
  titleTr?: string;
  variant?: "bar" | "rail";
}
const { url, urlTr, title, titleTr = title, variant = "bar" } = Astro.props;
const isRail = variant === "rail";
const render = (tpl: string) =>
  tpl.replaceAll("{u}", encodeURIComponent(url)).replaceAll("{t}", encodeURIComponent(title));

