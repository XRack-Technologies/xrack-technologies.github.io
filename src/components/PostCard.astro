---
import { href, formatDate, formatDateTr } from "../lib/site";
import { readingMinutes, renderBilingual } from "../lib/i18n";
import T from "./T.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}
const { post } = Astro.props;
const { title, description, pubDate, tags, author, cover } = post.data;
const titleTr = post.data.title_tr ?? title;
const descriptionTr = post.data.description_tr ?? description;
const primaryTag = tags[0];
const mins = readingMinutes(post.body ?? "");
const dual = !!post.data.title_tr || !!post.data.description_tr;
const hasTr = renderBilingual(post.body ?? "").bilingual || dual;
const search = [title, titleTr, description, descriptionTr, ...tags].join(" ").toLowerCase();
const hues = ["6 62% 50%", "12 62% 62%", "22 75% 58%", "348 58% 60%"];
const hueSeed = [...(primaryTag ?? "xrack")].reduce((s, ch) => s + ch.charCodeAt(0), 0);
const hue = hues[hueSeed % hues.length];
---

<article
  class="card-chrome reveal-on-view post-card"
  data-tags={tags.join(" ")}
  data-date={pubDate.toISOString()}
  data-search={search}
>
  <a class="post-card__link" href={href(`blog/${post.id}`)} data-href-tr={hasTr ? href(`blog/${post.id}/tr`) : undefined}>
    <div class="post-card__cover">
      {
        cover ? (
          <img src={cover} alt="" loading="lazy" />
        ) : (
          <span class="post-card__cover-ph" style={`--cov:${hue}`}>{primaryTag ?? "XRack"}</span>
        )
      }
    </div>
    <div class="post-card__body">
      <div class="post-card__meta">
        {primaryTag && <span class="pill pill-primary">{primaryTag}</span>}
        <time datetime={pubDate.toISOString()}>
          <span data-lang-content="en">{formatDate(pubDate)}</span>
          <span data-lang-content="tr">{formatDateTr(pubDate)}</span>
        </time>
        <span class="dot" aria-hidden="true">&middot;</span>
        <span><T en={`${mins} min read`} tr={`${mins} dk okuma`} /></span>
      </div>
      <h2 class="post-card__title">
        {
          dual ? (
            <>
              <span data-lang-content="en">{title}</span>
              <span data-lang-content="tr">{titleTr}</span>
            </>
          ) : (
            title
          )
        }
      </h2>
      <p class="post-card__excerpt">
        {
          dual ? (
            <>
              <span data-lang-content="en">{description}</span>
              <span data-lang-content="tr">{descriptionTr}</span>
            </>
          ) : (
            description
          )
        }
      </p>
      <div class="post-card__foot">
        <span>{author}</span>
        <span class="read"><T en="Read" tr="Oku" /> <span aria-hidden="true">&rarr;</span></span>
      </div>
    </div>
  </a>
</article>
