---
// Bilingual UI string: renders both languages; the active one is shown via CSS
// (html[data-lang]). Usage: <T en="Latest" tr="En Yeni" />
interface Props {
  en: string;
  tr: string;
}
const { en, tr } = Astro.props;
---
<span data-lang-content="en">{en}</span><span data-lang-content="tr">{tr}</span>
